{
  "name": "apex-chat-messaging",
  "version": "1.1.17",
  "private": true,
  "type": "module",
  "description": "Apex Chat — PWA messagerie chiffrée privée Kevin DESARZENS",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "echo 'no eslint config yet'",
    "validate": "node --check sw.js && node --check crypto.js && node --check workers/api-worker.js",
    "test:e2e": "playwright test",
    "test:e2e:iphone": "playwright test --project=iphone-safari",
    "test:e2e:install": "playwright install --with-deps",
    "test:all": "npm run test && npm run test:e2e"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "happy-dom": "^14.12.0",
    "@vitest/ui": "^1.6.0",
    "@playwright/test": "^1.49.0",
    "http-server": "^14.1.1"
  }
}