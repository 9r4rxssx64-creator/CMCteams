{
  "name": "apex-ai-ts",
  "version": "0.1.0",
  "description": "Apex AI TypeScript migration layer (Vite + Vitest) - sécurité orthographe code",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
