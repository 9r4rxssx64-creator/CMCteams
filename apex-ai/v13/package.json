{
  "name": "apex-v13",
  "private": true,
  "version": "13.4.9",
  "type": "module",
  "description": "APEX AI v13 — Rebuild propre niveau entreprise commercialisable",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,css,html,md,json}\"",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lighthouse": "lhci autorun",
    "axe": "axe-core --include='./'",
    "size": "size-limit",
    "audit:all": "npm run typecheck && npm run lint && npm run test && npm run build && npm run size"
  },
  "dependencies": {
    "dompurify": "^3.2.4",
    "fuse.js": "^7.0.0",
    "lucide-static": "^0.460.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.49.0",
    "@size-limit/preset-app": "^11.1.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.0.0",
    "prettier": "^3.4.0",
    "size-limit": "^11.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "tmp": "^0.2.4",
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0"
  },
  "size-limit": [
    {
      "path": "dist/index.html",
      "limit": "30 KB",
      "name": "Shell HTML"
    },
    {
      "path": "dist/assets/css/*.css",
      "limit": "30 KB gzip",
      "gzip": true,
      "name": "CSS bundle"
    },
    {
      "path": "dist/core/bootstrap-*.js",
      "limit": "80 KB gzip",
      "gzip": true,
      "name": "Core bundle"
    }
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
