+    const f = e.target.files[0]; if (!f) return;
+    const reader = new FileReader();
+    reader.onload = () => {
+      try {
+        const j = JSON.parse(reader.result);
+        if (j.theme) setTheme(j.theme);
+        if (j.mode) setMode(j.mode);
+        if (j.custom_macros) { A.customMacros = j.custom_macros; ss("custom_macros", A.customMacros); }
+        if (j.clone_library) { A.cloneLibrary = j.clone_library; ss("clone_library", A.cloneLibrary); }
+        toast("✅ Import réussi", "ok");
+        render();
