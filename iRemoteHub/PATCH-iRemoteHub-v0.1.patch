++            type: svc.type, name: svc.name, port: svc.port, txt: svc.txt
++          });
++          existing.confidence = 25;
++          found.set(key, existing);
++        });
++      } catch { return null; }
++    });
++
++    setTimeout(() => {
++      try { browsers.forEach(b => b && b.stop && b.stop()); bonjour.destroy(); } catch {}
