+  const label = prompt("Nom du tag (ex: 🚪 Porte bureau) :", "Tag NFC " + new Date().toLocaleTimeString());
+  if (!label) return;
+  const entry = { format: "NFC_NDEF", label, serial: r.serialNumber, records: r.records, hardware: "Web NFC" };
+  await saveCloneEntry(entry);
+}
+
+async function cloneEmitNDEF(entry) {
+  await ensureDisclaimer();
+  const text = entry.records && entry.records[0] && entry.records[0].data ? entry.records[0].data : prompt("Texte à écrire :");
+  if (!text) return;
+  await nfcWrite(text);
+}
+
+async function ensureDisclaimer() {
