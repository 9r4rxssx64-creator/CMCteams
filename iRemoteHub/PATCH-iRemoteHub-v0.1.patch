++const CONFIG_PATH = path.join(__dirname, 'config.json');
++let CONFIG = {
++  port: 7070,
++  auth_token: crypto.randomBytes(32).toString('hex'),
++  scan_interval_ms: 60000,
++  enable_ble: false,
++  enable_ir: true,
