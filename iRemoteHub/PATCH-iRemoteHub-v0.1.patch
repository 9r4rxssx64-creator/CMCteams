+// Samsung Tizen TV — WebSocket :8001/:8002
+let SamsungTV;
+try { SamsungTV = require('samsung-tv-control').default; } catch {}
+
+function client(d) {
+  if (!SamsungTV) throw new Error('samsung-tv-control non installé');
