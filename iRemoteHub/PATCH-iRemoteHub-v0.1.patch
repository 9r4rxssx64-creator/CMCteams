+  ss("clone_library", A.cloneLibrary);
+  if (A.bridgeUrl) { try { await apiPost("/clone/library", entry); } catch {} }
+  toast("💾 \"" + entry.label + "\" sauvegardé", "ok");
+  fire("clone:saved", entry);
+  if (A.view === "clone") render();
+}
