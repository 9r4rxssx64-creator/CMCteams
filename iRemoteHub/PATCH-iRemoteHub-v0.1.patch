+.device .sub { font-size: .75rem; color: var(--fg-dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.device .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--fg-dim); margin-right: 4px; }
+.device .dot.on { background: var(--ok); box-shadow: 0 0 6px var(--ok); }
+.device .dot.off { background: var(--danger); }
+
+.macro {
+  display: flex; flex-direction: column; align-items: center; justify-content: center;
+  background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
+  padding: 14px 8px; min-height: 88px; gap: 6px; font-size: .85rem;
+}
+.macro .ic { font-size: 1.6rem; }
+.macro:hover { border-color: var(--accent); }
+
+.toast {
+  position: fixed; top: calc(var(--tpad) + 50px); left: 50%; transform: translateX(-50%);
+  background: var(--bg2); border: 1px solid var(--accent); border-radius: 12px;
+  padding: 10px 16px; font-size: .9rem; box-shadow: var(--shadow); z-index: 100;
+  animation: toastIn .25s ease-out;
+}
+.toast.ok { border-color: var(--ok); color: var(--ok); }
+.toast.err { border-color: var(--danger); color: var(--danger); }
+@keyframes toastIn { from { opacity: 0; transform: translate(-50%, -10px); } to { opacity: 1; transform: translate(-50%, 0); } }
+
+.row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
+.row > * { flex: 0 0 auto; }
+.row.between { justify-content: space-between; }
+.gap-10 { display: flex; gap: 10px; flex-wrap: wrap; }
+.muted { color: var(--fg-dim); }
+.tiny { font-size: .75rem; }
+.center { text-align: center; }
+.spread { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
+
+.remote {
+  display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; max-width: 360px; margin: 0 auto;
+}
+.remote button { aspect-ratio: 1; font-size: 1.1rem; }
+.slider { width: 100%; height: 32px; accent-color: var(--accent); }
+
+label { display: block; font-size: .8rem; color: var(--fg-dim); margin: 8px 0 4px 0; }
+
+.kbd { font-family: var(--mono); font-size: .8rem; background: rgba(255,255,255,.06); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }
+.warn { background: rgba(255,181,71,.12); border-left: 3px solid var(--warn); padding: 10px 12px; border-radius: 6px; font-size: .85rem; }
+.danger-banner { background: rgba(226,85,85,.12); border-left: 3px solid var(--danger); padding: 10px 12px; border-radius: 6px; font-size: .85rem; }
+.ok-banner { background: rgba(76,217,122,.12); border-left: 3px solid var(--ok); padding: 10px 12px; border-radius: 6px; font-size: .85rem; }
+
+.modepick { display: flex; gap: 4px; padding: 3px; background: var(--bg2); border-radius: 12px; border: 1px solid var(--border); }
+.modepick button { flex: 1; min-height: 36px; padding: 6px 8px; font-size: .8rem; background: transparent; border: none; border-radius: 9px; }
+.modepick button.active { background: var(--accent); color: #1b1300; font-weight: 600; }
+
+.recbtn {
+  position: fixed; top: calc(var(--tpad) + 50px); right: var(--hpad); z-index: 80;
+  background: var(--danger); color: #fff; border: none; border-radius: 999px;
+  padding: 10px 16px; font-size: .85rem; font-weight: 600;
+  box-shadow: 0 4px 20px rgba(226,85,85,.4); display: none; align-items: center; gap: 6px;
+}
+.recbtn.rec { display: flex; animation: pulse 1.2s infinite; }
+@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.6} }
+
+.qr {
+  display: inline-block; padding: 12px; background: #fff; border-radius: 8px;
+}
+
+.hide { display: none !important; }
+
+@media (prefers-reduced-motion: reduce) {
+  * { animation-duration: .01s !important; transition-duration: .01s !important; }
+}
+</style>
+</head>
+<body>
+<div id="topbar">
+  <span class="logo" aria-label="iRemoteHub">🎛️ iRemoteHub</span>
+  <span id="bridge-badge" class="badge" title="État du bridge">⚪ bridge</span>
+  <button class="icbtn" id="btn-mode" title="Mode contextuel" aria-label="Changer de mode">☀️</button>
+  <button class="icbtn" id="btn-theme" title="Changer de thème" aria-label="Changer de thème">🎨</button>
+</div>
+<button class="recbtn" id="recbtn" aria-label="Enregistrement macro en cours">⏺ <span id="rec-count">0</span></button>
+<main id="app" role="main"></main>
+<nav id="bnav" role="navigation" aria-label="Navigation principale">
+  <button data-view="accueil"><span class="ic">🏠</span><span class="lbl">Accueil</span></button>
+  <button data-view="scanner"><span class="ic">🔍</span><span class="lbl">Scan</span></button>
+  <button data-view="macros"><span class="ic">🪄</span><span class="lbl">Macros</span></button>
+  <button data-view="clone"><span class="ic">📇</span><span class="lbl">Clone</span></button>
+  <button data-view="ia"><span class="ic">🤖</span><span class="lbl">IA</span></button>
+  <button data-view="settings"><span class="ic">⚙️</span><span class="lbl">Réglages</span></button>
+</nav>
+
+<script>
+"use strict";
+
+// ========== Constantes ==========
+const APP_VER = "v0.1.0";
+const NS = "iremotehub_";
+const APEX_ORIGINS = ["https://apex.local", "https://localhost", window.location.origin];
+
+// ========== Sécurité — escape HTML ==========
+const ESCMAP = { "&":"&amp;", "<":"&lt;", ">":"&gt;", '"':"&quot;", "'":"&#39;", "/":"&#x2F;" };
+function esc(s) {
+  if (s == null) return "";
+  return String(s).replace(/[&<>"'/]/g, c => ESCMAP[c]);
+}
+
+// ========== État global ==========
+const A = {
+  devices: new Map(),
+  view: "accueil",
+  theme: "casino",
+  mode: "jour",
+  bridgeUrl: "",
+  token: "",
+  embedded: window.parent !== window,
+  cloneLibrary: [],
+  customMacros: [],
+  selectedDevice: null,
+  bridgeOnline: false,
+  ws: null,
+  disclaimerAccepted: false,
+  recording: null
+};
+
+const THEMES = ["casino", "nuit", "jour", "arcade", "pro"];
+const THEME_LABELS = { casino: "🎰 Casino", nuit: "🌃 Nuit", jour: "☀️ Jour", arcade: "🎮 Arcade", pro: "🏢 Pro" };
+
+const MODES = ["jour", "nuit", "enfant", "invite"];
+const MODE_LABELS = { jour: "☀️ Jour", nuit: "🌙 Nuit", enfant: "👶 Enfant", invite: "👥 Invité" };
+
+const CATEGORY_ICONS = { tv: "📺", speaker: "🔊", cast: "🎬", light: "💡", plug: "🔌", watch: "⌚", phone: "📱", tablet: "📋", hub: "🏠", homekit: "🏡", ir: "📡", camera: "📷", car: "🚗", game: "🎮", unknown: "❓" };
+
+const BUILTIN_MACROS = [
+  { id: "all-off", name: "Tout éteindre", ic: "🌙", desc: "Coupe TV, enceintes, lumières, prises" },
+  { id: "cinema", name: "Soirée ciné", ic: "🎬", desc: "Lumières tamisées + TV HDMI2 + son 30%" },
+  { id: "panic-silence", name: "Panique silence", ic: "🔇", desc: "Mute toutes sources sonores" },
+  { id: "morning", name: "Réveil matin", ic: "☀️", desc: "Lumières montent progressivement" }
+];
+
+// ========== LocalStorage ==========
+function ls(k, def) {
+  try { const v = localStorage.getItem(NS + k); return v == null ? def : JSON.parse(v); }
+  catch { return def; }
+}
+function ss(k, v) {
+  try { localStorage.setItem(NS + k, JSON.stringify(v)); } catch {}
+}
+function lsRemove(k) { try { localStorage.removeItem(NS + k); } catch {} }
+
+// ========== Toast ==========
+let toastTimer = null;
+function toast(msg, type) {
+  const old = document.querySelector(".toast");
+  if (old) old.remove();
+  clearTimeout(toastTimer);
+  const el = document.createElement("div");
+  el.className = "toast" + (type ? " " + type : "");
+  el.textContent = msg;
+  el.setAttribute("role", "status");
+  document.body.appendChild(el);
+  toastTimer = setTimeout(() => { el.style.opacity = "0"; setTimeout(() => el.remove(), 300); }, 3000);
+}
+
+// ========== Themes & modes ==========
+function setTheme(name) {
+  if (!THEMES.includes(name)) name = "casino";
+  A.theme = name;
+  document.documentElement.dataset.theme = name;
+  ss("theme", name);
+  const colors = { casino:"#d4af37", nuit:"#5b8def", jour:"#1d6f5b", arcade:"#ff3df8", pro:"#2854c5" };
+  const meta = document.querySelector('meta[name="theme-color"]');
+  if (meta) meta.setAttribute("content", colors[name]);
+  emitApex("theme:changed", { theme: name });
+}
+
+function cycleTheme() {
+  const i = THEMES.indexOf(A.theme);
+  setTheme(THEMES[(i + 1) % THEMES.length]);
+  toast(THEME_LABELS[A.theme]);
+}
+
+function setMode(name) {
+  if (!MODES.includes(name)) name = "jour";
+  A.mode = name;
+  ss("mode", name);
+  document.getElementById("btn-mode").textContent = MODE_LABELS[name].split(" ")[0];
+  if (A.view) render();
+  emitApex("mode:changed", { mode: name });
+}
+
+function cycleMode() {
+  const i = MODES.indexOf(A.mode);
+  setMode(MODES[(i + 1) % MODES.length]);
+  toast(MODE_LABELS[A.mode]);
+}
+
+// ========== Bridge API ==========
+function headers() {
+  const h = { "Content-Type": "application/json" };
+  if (A.token) h["X-Auth-Token"] = A.token;
+  return h;
+}
+
+async function apiGet(path, opts) {
+  if (!A.bridgeUrl) throw new Error("Bridge non configuré");
+  const r = await fetch(A.bridgeUrl + path, { headers: headers(), ...opts });
+  if (!r.ok) throw new Error("Bridge HTTP " + r.status);
+  return await r.json();
+}
+
+async function apiPost(path, body, opts) {
+  if (!A.bridgeUrl) throw new Error("Bridge non configuré");
+  const r = await fetch(A.bridgeUrl + path, { method: "POST", headers: headers(), body: JSON.stringify(body || {}), ...opts });
+  if (!r.ok) {
+    let j; try { j = await r.json(); } catch {}
+    throw new Error((j && j.error) || ("Bridge HTTP " + r.status));
+  }
+  return await r.json();
+}
+
+async function apiDelete(path) {
+  const r = await fetch(A.bridgeUrl + path, { method: "DELETE", headers: headers() });
+  if (!r.ok) throw new Error("Bridge HTTP " + r.status);
+  return await r.json();
+}
+
+async function pingBridge() {
+  if (!A.bridgeUrl) return setBridgeStatus(false);
+  try {
+    const r = await fetch(A.bridgeUrl + "/health", { signal: AbortSignal.timeout(2500) });
+    setBridgeStatus(r.ok);
+  } catch { setBridgeStatus(false); }
+}
+
+function setBridgeStatus(online) {
+  A.bridgeOnline = online;
+  const el = document.getElementById("bridge-badge");
+  if (online) { el.className = "badge ok"; el.textContent = "🟢 bridge"; }
+  else { el.className = "badge warn"; el.textContent = "🟡 hors-ligne"; }
+}
+
+function connectWS() {
+  if (!A.bridgeUrl || !A.token) return;
+  try {
+    if (A.ws) { try { A.ws.close(); } catch {} A.ws = null; }
+    const wsUrl = A.bridgeUrl.replace(/^http/, "ws") + "/events?token=" + encodeURIComponent(A.token);
+    const ws = new WebSocket(wsUrl);
+    A.ws = ws;
+    ws.onopen = () => setBridgeStatus(true);
+    ws.onmessage = (e) => {
+      try {
+        const msg = JSON.parse(e.data);
+        if (msg.type === "hello" && msg.devices) {
+          for (const d of msg.devices) A.devices.set(d.id, d);
+          if (A.view === "scanner" || A.view === "accueil") render();
+        }
+        if (msg.type === "devices:update" || msg.type === "scan:done") {
+          loadDevices();
+        }
+        emitApex("event:" + msg.type, msg);
+      } catch {}
+    };
+    ws.onclose = () => { setBridgeStatus(false); setTimeout(connectWS, 5000); };
+    ws.onerror = () => {};
+  } catch {}
+}
+
+async function loadDevices() {
+  if (!A.bridgeUrl) return;
+  try {
+    const list = await apiGet("/devices");
+    A.devices.clear();
+    for (const d of list) A.devices.set(d.id, d);
+    if (A.view === "scanner" || A.view === "accueil") render();
+  } catch (e) { /* silent */ }
+}
+
+// ========== Mode APEX embedded ==========
+function emitApex(type, data) {
+  if (!A.embedded) return;
+  try { window.parent.postMessage({ from: "iremotehub", type, version: APP_VER, data }, "*"); } catch {}
+}
+
+function setupApexBridge() {
+  window.addEventListener("message", (e) => {
+    if (!e.data || e.data.from !== "apex") return;
+    const ok = APEX_ORIGINS.includes(e.origin) || /^https?:\/\/(localhost|127\.|192\.168\.|10\.|apex)/i.test(e.origin);
+    if (!ok) return;
+    const { command, args } = e.data;
+    try { handleApexCommand(command, args || []); }
+    catch (err) { emitApex("error", { message: err.message }); }
+  });
+}
+
+async function handleApexCommand(cmd, args) {
+  switch (cmd) {
+    case "runMacro": return runMacro(args[0]);
+    case "scanNow": return scanNow();
+    case "setTheme": return setTheme(args[0]);
+    case "setMode": return setMode(args[0]);
+    case "getDevices": return emitApex("response:getDevices", { devices: [...A.devices.values()] });
+    case "identifyDevice": return iaIdentify(args[0]);
+    case "reload": return location.reload();
+    case "setBridge":
+      A.bridgeUrl = args[0] || "";
+      A.token = args[1] || "";
+      ss("bridge_url", A.bridgeUrl); ss("bridge_token", A.token);
+      await pingBridge(); connectWS();
+      return;
+    default: throw new Error("commande inconnue : " + cmd);
+  }
+}
+
+// ========== API publique iRemoteHub ==========
+const listeners = new Map();
+window.iRemoteHub = {
+  version: APP_VER,
+  get mode() { return A.embedded ? "embedded" : "standalone"; },
+  init(config) {
+    if (config && config.bridge_url) { A.bridgeUrl = config.bridge_url; ss("bridge_url", A.bridgeUrl); }
+    if (config && config.token) { A.token = config.token; ss("bridge_token", A.token); }
+    if (config && config.theme) setTheme(config.theme);
+    if (config && config.mode) setMode(config.mode);
+    pingBridge(); connectWS();
+  },
+  getDevices() { return [...A.devices.values()]; },
+  getMacros() { return [...BUILTIN_MACROS, ...A.customMacros]; },
+  getCloneLibrary() { return [...A.cloneLibrary]; },
+  getTheme() { return A.theme; },
+  runMacro,
+  scanNow,
+  identifyDevice: iaIdentify,
+  setTheme,
+  setMode,
+  on(event, cb) { (listeners.get(event) || listeners.set(event, []).get(event)).push(cb); },
+  off(event, cb) { const arr = listeners.get(event); if (arr) listeners.set(event, arr.filter(f => f !== cb)); },
+  destroy() { try { A.ws && A.ws.close(); } catch {} }
+};
+
+function fire(event, data) {
+  (listeners.get(event) || []).forEach(cb => { try { cb(data); } catch {} });
+  emitApex("event:" + event, data);
+}
+
+// ========== Actions ==========
+async function runMacro(name) {
+  if (!A.bridgeUrl) { toast("Configure le bridge dans Réglages", "err"); return; }
+  if (A.mode === "invite") { toast("Mode invité : actions désactivées", "err"); return; }
+  try {
+    toast("🪄 " + name + "…");
+    const r = await apiPost("/macro/" + encodeURIComponent(name), { source: A.embedded ? "apex" : "pwa" });
+    toast("✅ " + name + " — " + (r.results ? r.results.length : 0) + " action(s)", "ok");
+    fire("macro:done", { name, result: r });
+    return r;
+  } catch (e) {
+    toast("❌ " + e.message, "err");
+    throw e;
+  }
+}
+
+async function scanNow() {
+  if (!A.bridgeUrl) { toast("Configure le bridge", "err"); return; }
+  try {
+    toast("🔍 Scan en cours…");
+    const r = await apiPost("/scan", {});
+    toast("✅ " + r.count + " appareil(s) détecté(s)", "ok");
+    loadDevices();
+    return r;
+  } catch (e) { toast("❌ " + e.message, "err"); }
+}
+
+async function doAction(deviceId, action, params) {
+  if (A.mode === "invite") { toast("Mode invité : lecture seule", "err"); return; }
+  if (A.mode === "enfant" && /power_off|delete|reset/i.test(action)) { toast("Mode enfant : action bloquée", "err"); return; }
+  if (A.recording) recAdd({ device_id: deviceId, action, params });
+  try {
+    const r = await apiPost("/action", { device_id: deviceId, action, params: params || {} });
+    toast("✅ " + action, "ok");
+    return r;
+  } catch (e) { toast("❌ " + e.message, "err"); throw e; }
+}
+
+async function iaIdentify(deviceId) {
+  const d = A.devices.get(deviceId);
+  if (!d) { toast("Appareil inconnu", "err"); return; }
+  try {
+    toast("🤖 Identification IA…");
+    const fingerprint = buildFingerprint(d);
+    const r = await apiPost("/identify", { fingerprint });
+    toast("✅ " + (r.vendor || "?") + " " + (r.model || ""), "ok");
+    Object.assign(d, { ia: r });
+    A.devices.set(deviceId, d);
+    render();
+    fire("device:identified", { device_id: deviceId, identification: r });
+    return r;
+  } catch (e) { toast("❌ " + e.message, "err"); }
+}
+
+function buildFingerprint(d) {
+  return {
+    network: { mac: d.mac, mac_oui_vendor: d.vendor, ipv4: d.ip, hostname: d.hostname },
+    tcp_ip: { open_ports: d.open_ports || [], banner_http: d.banner_http || "" },
+    mdns: d.mdns || [],
+    ssdp: d.ssdp || [],
+    ble: d.ble_address ? { name: d.name, address: d.ble_address, rssi: d.rssi, services_uuids: d.services_uuids } : undefined,
+    category: d.category
+  };
+}
+
+// ========== Macro recorder ==========
+function recStart() {
+  A.recording = { id: "macro-" + Date.now().toString(36), name: "", actions: [], started: Date.now() };
+  document.getElementById("recbtn").classList.add("rec");
+  document.getElementById("rec-count").textContent = "0";
+  toast("⏺ Enregistrement démarré", "ok");
+}
+
+function recAdd(action) {
+  if (!A.recording) return;
+  A.recording.actions.push({ ...action, t: Date.now() - A.recording.started });
+  document.getElementById("rec-count").textContent = A.recording.actions.length;
+}
+
+function recStop() {
+  if (!A.recording) return;
+  const name = prompt("Nom de la macro :", "Ma macro " + new Date().toLocaleTimeString());
+  if (!name) { A.recording = null; document.getElementById("recbtn").classList.remove("rec"); return; }
+  A.recording.name = name;
+  A.recording.ic = "⭐";
+  A.customMacros.push(A.recording);
+  ss("custom_macros", A.customMacros);
+  toast("💾 Macro \"" + name + "\" sauvegardée", "ok");
+  fire("macro:recorded", A.recording);
+  A.recording = null;
+  document.getElementById("recbtn").classList.remove("rec");
+  if (A.view === "macros") render();
+}
+
+async function playCustomMacro(macroId) {
+  const m = A.customMacros.find(x => x.id === macroId);
+  if (!m) return;
+  toast("▶ " + m.name);
+  for (const step of m.actions) {
+    try { await apiPost("/action", { device_id: step.device_id, action: step.action, params: step.params }); }
+    catch (e) { toast("⚠ " + step.action + " : " + e.message, "err"); }
+  }
+  toast("✅ " + m.name + " terminée", "ok");
+}
+
+// ========== Apple Shortcuts ==========
+function isIOS() { return /iPad|iPhone|iPod/.test(navigator.userAgent); }
+function callShortcut(name, input) {
+  const url = "shortcuts://x-callback-url/run-shortcut?name=" + encodeURIComponent(name) +
+              "&x-success=" + encodeURIComponent(location.href) +
+              "&x-error=" + encodeURIComponent(location.href);
+  window.location.href = url;
+}
+
+// ========== Web NFC (Android Chrome) ==========
+async function nfcScan() {
+  if (!("NDEFReader" in window)) { toast("Web NFC indisponible (Chrome Android requis)", "err"); return null; }
+  try {
+    const reader = new NDEFReader();
+    await reader.scan();
+    toast("📡 Approchez un tag NFC", "ok");
+    return new Promise((resolve) => {
+      reader.onreading = (event) => {
+        const records = [];
+        for (const rec of event.message.records) {
+          records.push({ recordType: rec.recordType, mediaType: rec.mediaType, data: rec.data && new TextDecoder().decode(rec.data) });
+        }
+        resolve({ serialNumber: event.serialNumber, records });
+      };
+      setTimeout(() => resolve(null), 30000);
+    });
+  } catch (e) { toast("❌ NFC : " + e.message, "err"); return null; }
+}
+
+async function nfcWrite(text) {
+  if (!("NDEFReader" in window)) { toast("Web NFC indisponible", "err"); return false; }
+  try {
+    const writer = new NDEFReader();
+    await writer.write({ records: [{ recordType: "text", data: text }] });
+    toast("✅ Tag écrit", "ok");
+    return true;
+  } catch (e) { toast("❌ " + e.message, "err"); return false; }
+}
+
+// ========== Web Bluetooth (Android Chrome) ==========
+async function bleScan() {
+  if (!navigator.bluetooth) { toast("Web Bluetooth indisponible (Chrome Android)", "err"); return; }
+  try {
+    const device = await navigator.bluetooth.requestDevice({ acceptAllDevices: true, optionalServices: ["battery_service","device_information"] });
+    toast("🔵 " + (device.name || "Appareil BLE") + " sélectionné", "ok");
+    const id = "ble-" + (device.id || Date.now());
+    A.devices.set(id, { id, name: device.name, category: "unknown", sources: ["ble-web"], vendor: "BLE (web)" });
+    render();
+    fire("device:found", A.devices.get(id));
+  } catch (e) { if (e.name !== "NotFoundError") toast("❌ " + e.message, "err"); }
+}
+
+// ========== Clone ==========
+async function cloneReadNDEF() {
+  await ensureDisclaimer();
