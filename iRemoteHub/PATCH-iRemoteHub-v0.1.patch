+    ip: d.ip,
+    mac: d.mac || '00:00:00:00:00:00',
+    nameApp: 'iRemoteHub',
+    debug: false,
+    token: d.samsung_token
+  });
+}
+
+const KEY = {
+  power_off: 'KEY_POWEROFF',
+  power_on: 'KEY_POWERON',
+  volume_up: 'KEY_VOLUP',
+  volume_down: 'KEY_VOLDOWN',
+  mute: 'KEY_MUTE',
+  home: 'KEY_HOME',
+  back: 'KEY_RETURN',
