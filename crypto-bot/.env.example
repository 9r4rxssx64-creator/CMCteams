# ============================================================
#  CONFIG BOT CRYPTO — copie ce fichier en ".env" et remplis-le
#  Le fichier .env est IGNORÉ par git (tes clés restent chez toi)
# ============================================================

# --- Clés API Binance ---
# IMPORTANT : sur Binance, quand tu crées la clé API,
#   ✅ coche "Enable Spot Trading"
#   ❌ NE COCHE JAMAIS "Enable Withdrawals" (retraits)
#   ✅ restreins la clé à ton adresse IP si possible
# Pour le TESTNET : crée tes clés sur https://testnet.binance.vision
BINANCE_API_KEY=colle_ta_cle_ici
BINANCE_API_SECRET=colle_ton_secret_ici

# --- Sécurité : mode testnet (faux argent) ---
# true  = faux argent (par défaut, aucun risque) — commence TOUJOURS ici
# false = ARGENT RÉEL (ne passe à false qu'après validation en testnet)
TESTNET=true

# --- Marché & rythme ---
SYMBOL=BTC/USDT
TIMEFRAME=15m
# Intervalle entre deux vérifications (secondes)
LOOP_SECONDS=60

# --- Stratégie (croisement EMA + filtre RSI + stop ATR) ---
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
RSI_MAX=70          # n'achète pas si RSI au-dessus (déjà trop haut)
ATR_PERIOD=14
ATR_STOP_MULT=2.0   # stop-loss = prix d'entrée - (ATR x ce multiple)

# --- Gestion du risque (garde-fous) ---
RISK_PER_TRADE_PCT=1.0   # % du capital risqué par trade
MAX_POSITION_PCT=25.0    # % max du capital sur une position
DAILY_LOSS_CAP_PCT=3.0   # si perte du jour dépasse ça -> le bot se coupe
MAX_DRAWDOWN_PCT=15.0    # si baisse depuis le sommet dépasse ça -> le bot se coupe
MIN_ORDER_USDT=11        # taille d'ordre minimale (Binance impose ~10 USDT)
