# =====================================================================
# Apex Audit Pipeline — variables d'environnement
# Copier en .env (ne JAMAIS commit) puis remplir les valeurs.
# =====================================================================

# --- Anthropic / Claude ----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-5-20250514
ANTHROPIC_MAX_TOKENS=8000

# --- Webhook n8n -----------------------------------------------------------
# Token attendu dans l'en-tête HTTP `X-KDMC-Token` côté webhook n8n.
KDMC_WEBHOOK_SECRET=change-me-32-chars-min-please

# URL publique du webhook (pour tests/curl).
KDMC_WEBHOOK_URL=https://n8n.kdmc.local/webhook/apex-audit

# --- Base de données -------------------------------------------------------
# Format : postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://kdmc_user:CHANGE_ME@db.kdmc.local:5432/kdmc?sslmode=require

# --- Email (notifications Kevin) -------------------------------------------
SMTP_HOST=smtp.kdmc.local
SMTP_PORT=587
SMTP_USER=apex-pipeline@kdmc.local
SMTP_PASSWORD=change-me
SMTP_FROM=apex-pipeline@kdmc.local
KEVIN_EMAIL=kevin.desarzens@gmail.com

# --- Script Python (Option B) ---------------------------------------------
APEX_AUDIT_INPUT=./examples/audit.json
APEX_AUDIT_OUTPUT_DIR=./out
LOG_LEVEL=INFO
