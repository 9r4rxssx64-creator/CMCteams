{
  "name": "apex-ios-companion",
  "version": "0.1.0-scaffold",
  "private": true,
  "description": "Apex iOS Companion — Capacitor wrapper unlocking Bluetooth/NFC/USB on iOS",
  "scripts": {
    "init": "echo 'Run: npm install && npx cap add ios && npx cap sync ios && npx cap open ios'",
    "build-web": "cd ../apex-ai/v13 && npm run build",
    "sync": "npx cap sync ios",
    "open-ios": "npx cap open ios",
    "run-ios": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/preferences": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
