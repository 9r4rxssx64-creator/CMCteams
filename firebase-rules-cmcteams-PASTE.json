{
  "rules": {
    ".read": false,
    ".write": false,
    "cmcteams": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$key": {
        ".validate": "$key.matches(/^cmc_[a-z0-9_\\-]+$/)"
      },
      "cmc_admin_pin": {
        ".write": false
      },
      "cmc_ia_key": {
        ".write": false
      },
      "cmc_motd": {
        ".validate": "newData.hasChildren(['text','ts','author']) || newData.val() === null"
      },
      "cmc_e": {
        ".validate": "newData.isString() == false"
      },
      "cmc_ov": {
        ".validate": "newData.isString() == false"
      },
      "cmc_pw": {
        ".validate": "newData.isString() == false",
        "$uid": {
          "clear": {
            ".validate": false
          }
        }
      }
    },
    "apex": {
      ".read": true,
      ".write": true,
      "$key": {
        ".validate": "$key.matches(/^ax_[a-z0-9_\\-]+$/)"
      },
      "ax_admin_pass": {
        ".write": false
      },
      "ax_admin_pin": {
        ".write": false
      },
      "ax_pin": {
        ".write": false
      },
      "ax_user": {
        ".write": false
      },
      "ax_uid": {
        ".write": false
      }
    },
    "coffre_vault": {
      ".read": true,
      ".write": true,
      "$uid": {
        ".validate": "$uid.matches(/^u_[a-z0-9]+$/)",
        "salt": {
          ".validate": "newData.isString() && newData.val().length < 64"
        },
        "verify": {
          ".validate": "newData.isString() && newData.val().length < 4096"
        },
        "meta": {
          ".validate": "newData.isString() && newData.val().length < 5242880"
        },
        "chunks": {
          "$id": {
            ".validate": "$id.matches(/^it_[a-z0-9_\\-]+$/) && (newData.val() === null || (newData.isString() && newData.val().length < 1048576))"
          }
        }
      }
    },
    "shops_admin_v1": {
      "orders": {
        ".read": true,
        "$shop": {
          ".validate": "$shop.matches(/^(tech-hub|chez-lolo|ecocraft|digital-vault|pawsome)$/)",
          "$orderId": {
            ".write": "!data.exists() && newData.hasChildren(['orderId','shop','total','ts'])",
            ".validate": "newData.child('total').isNumber() && newData.child('total').val() >= 0 && newData.child('total').val() < 100000 && $orderId.length <= 40"
          }
        }
      }
    }
  }
}
