+// v9.107 — Déduction du secteur/famille selon les compétences (règle admin 2026-04-13)
+// Règle : E → européen (roulettes) · P/P+ sans E, case rose → groupe ouvert (cmc) · P/P+ sans E → baccara
+function deduceFamilyFromComp(post,pinkComp){
+  var comps=parseCompetences(post||"");
+  if(!comps.length)return null; // pas de compétences → ne rien changer
+  var hasE=comps.indexOf("E")>=0;
+  var hasP=comps.indexOf("P")>=0||comps.indexOf("P+")>=0;
+  if(hasE)return "roulettes";               // européen prioritaire
+  if(hasP&&pinkComp)return "cmc";           // P/P+ avec fond rose → groupe ouvert
+  if(hasP)return "baccara";                 // P/P+ seul → baccara
+  return null;                              // pas de règle applicable
+}
