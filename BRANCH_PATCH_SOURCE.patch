+        mime:file.type||"application/octet-stream",
+        size:dataUrl.length,
+        dataUrl:dataUrl,
+        description:desc,
+        category:category||"autres",
+        ts:Date.now(),
+        status:"pending"
+      };
+      A.uploadRequests=A.uploadRequests||[];
+      A.uploadRequests.push(req);
+      ls("cmc_upload_requests",A.uploadRequests);
+      _audit("upload_request",A.user.id,A.user.name||"","",file.name+" ("+(category||"autres")+")");
+      toast("\u2709\ufe0f Demande envoy\u00e9e \u00e0 l'admin pour validation");
+      // Notif navigateur admin (si admin en ligne sur un autre device)
+      try{sendNotif("\ud83d\udce4 Nouvelle demande upload","De "+(A.user.name||A.user.id)+" : "+file.name,{tag:"upload_req"});}catch(e){}
+      dc();
+    };
+    if(file.type.indexOf("image/")===0){
+      var budget=Math.round(DOC_MAX_SIZE*0.9);
+      _resizeImage(file,2000,2000,0.88,function(dataUrl,err){
+        if(err||!dataUrl){toast("Erreur : "+(err||"?"),"err");return;}
+        process(dataUrl);
+      },budget);
+    } else {
+      var reader=new FileReader();
+      reader.onload=function(r){process(r.target.result);};
+      reader.onerror=function(){toast("Erreur lecture","err");};
