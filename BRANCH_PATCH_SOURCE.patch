+// v9.81 — BACKUP AUTO QUOTIDIEN (sans intervention admin)
+// Créé automatiquement toutes les 24h, stocké dans localStorage + Firebase
+// Retient les 7 derniers backups (rotation auto)
+function _autoBackupIfNeeded(){
+  try{
+    var lastBackup=parseInt(localStorage.getItem("cmc_last_auto_backup")||"0",10);
+    var now=Date.now();
+    if(now-lastBackup<20*60*60*1000)return; // pas plus d'1 fois / 20h
+    var today=new Date().toISOString().slice(0,10); // "2026-04-12"
+    var key="cmc_auto_backup_"+today;
+    if(localStorage.getItem(key))return; // déjà fait aujourd'hui
+    var backup={
+      createdAt:new Date().toISOString(),
+      appVer:(typeof APP_VER!=="undefined"?APP_VER:"?"),
+      dataVer:(typeof DATA_VER!=="undefined"?DATA_VER:"?"),
+      employees:A.employees||[],
+      teams:A.teams||[],
+      overrides:A.overrides||{},
+      reg:A.reg||{},
+      motd:A.motd||null,
+      empCount:(A.employees||[]).length,
+      monthsCount:Object.keys(A.overrides||{}).length
+    };
+    // Note: on NE backup PAS les passwords (sécurité)
+    var json=JSON.stringify(backup);
+    try{localStorage.setItem(key,json);}catch(e){
+      // Quota plein → supprimer les vieux backups
+      _cleanOldBackups(2);
+      try{localStorage.setItem(key,json);}catch(e2){console.warn("Backup local échoué:",e2);return;}
+    }
+    localStorage.setItem("cmc_last_auto_backup",String(now));
+    // Nettoyer vieux backups (garder 7 derniers)
+    _cleanOldBackups(7);
+    // Push Firebase (non bloquant)
+    if(typeof fbWrite==="function")fbWrite("cmc_auto_backup_"+today,backup);
+    console.log("✅ Auto-backup "+today+" ("+Math.round(json.length/1024)+" KB)");
+    if(typeof _audit==="function")_audit("auto_backup",A.user?A.user.id:"system","",today,Math.round(json.length/1024)+" KB");
+  }catch(e){console.warn("Auto-backup erreur:",e);}
+}
