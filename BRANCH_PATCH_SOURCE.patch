+// Calcule le diff entre état avant et après import (sans l'appliquer)
+function _computeImportDiff(oldOv,newOv,oldEmps,newEmps,iy,im,snapshot,toastMsgs){
+  var diff={
+    year:iy,month:im,yearMonth:iy+"-"+im,
+    monthLabel:(MFR&&MFR[im])?MFR[im]+" "+iy:iy+"-"+im,
+    empAdded:[],       // employés nouvellement créés
+    empRetired:[],     // employés non présents dans le nouvel import
+    empPresent:0,      // nb emps avec planning inchangé
+    empModified:[],    // {id, name, changes:[{day, old, new}]}
+    unknownCodes:{},   // {code: count} codes non reconnus
+    conflictsBefore:0,
+    conflictsAfter:0,
+    suggestions:snapshot.importSuggestions,
+    toastMsgs:toastMsgs||[],
+    totalDays:getDays(iy,im)
+  };
+  // 1. Nouveaux employés (présents après mais pas avant)
+  var oldIds={};(oldEmps||[]).forEach(function(e){oldIds[e.id]=e;});
+  (newEmps||[]).forEach(function(e){if(!oldIds[e.id])diff.empAdded.push({id:e.id,name:e.name,team:e.team,family:e.family||"bj"});});
+  // 2. Modifications par employé
+  Object.keys(newOv).forEach(function(empId){
+    var newDays=newOv[empId]||{};
+    var oldDays=oldOv[empId]||{};
+    var emp=(newEmps||[]).find(function(e){return e.id===empId;})||{id:empId,name:empId};
+    var changes=[];
+    for(var d=1;d<=diff.totalDays;d++){
+      var oldC=oldDays[d]||"",newC=newDays[d]||"";
+      if(oldC!==newC)changes.push({day:d,old:oldC||"\u2205",new:newC||"\u2205"});
+      // Détecter codes inconnus
+      if(newC&&!(CODES&&CODES[newC])){
+        diff.unknownCodes[newC]=(diff.unknownCodes[newC]||0)+1;
+      }
+    }
+    if(changes.length>0)diff.empModified.push({id:empId,name:emp.name,changes:changes,changeCount:changes.length});
+    else diff.empPresent++;
+  });
+  // Trier modifications par nombre de changes desc
+  diff.empModified.sort(function(a,b){return b.changeCount-a.changeCount;});
+  // 3. Conflits (avant vs après) si fonction disponible
+  if(typeof detectRepoConflicts==="function"){
+    try{
+      // Avant : on restaure temporairement
+      var _saveOv=A.overrides;A.overrides=snapshot.overrides;
+      diff.conflictsBefore=(detectRepoConflicts(iy,im)||[]).length;
+      // Après : on remet le nouveau
+      A.overrides={};A.overrides[diff.yearMonth]=newOv;
+      diff.conflictsAfter=(detectRepoConflicts(iy,im)||[]).length;
+      A.overrides=_saveOv;
+    }catch(e){}
+  }
+  return diff;
+}
