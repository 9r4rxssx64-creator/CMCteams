+}
+
+// ── ONGLET ABSENCES ──────────────────────────────────────────────────────────
+function vAbsences(){
+  var pl=gpl(),days=getDays(A.year,A.month);
+  var daysArr=(function(n){var a=[];for(var i=0;i<n;i++)a.push(i+1);return a;})(days);
+  var isAdm=A.user&&A.user.id===AID;
+  var myTeam=A.user?A.user.team:null;
+  // Codes d'absence a afficher
+  var ABS_CODES={"CP":"#684060","M":"#783840","AF":"#206038","RRT":"#205060","HC":"#506818"};
+  var ABS_LBL={"CP":"Cong\u00e9","M":"Maladie","AF":"Formation","RRT":"R\u00e9cup","HC":"H.Comp."};
+
+  var h='<div class="page">';
+  h+='<div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">'
+   +'<button class="btn ghost" onclick="prevM()" style="padding:7px 13px;font-size:20px">\u2039</button>'
