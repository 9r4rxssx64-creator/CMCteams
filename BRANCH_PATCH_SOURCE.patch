+// Helper : recherche dans JEUX_SBM par mot-cl\u00e9
+function searchJeuxSBM(query){
+  if(!query)return[];
+  var q=query.toLowerCase();
+  var results=[];
+  Object.keys(JEUX_SBM).forEach(function(jid){
+    var j=JEUX_SBM[jid];
+    (j.sections||[]).forEach(function(sec){
+      if(sec.titre.toLowerCase().indexOf(q)>=0||(sec.paragraphes||[]).some(function(p){return p.toLowerCase().indexOf(q)>=0;})){
+        results.push({jeu:jid,section:sec.titre,source:j.source});
+      }
+    });
+  });
+  return results;
+}
