+// \u2500\u2500 MOTEUR DE V\u00c9RIFICATION \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
+function runVerification(year,month,refData){
+  var pl=gpl(); // planning tel qu'affich\u00e9 dans l'app
+  var ref=refData||lg("cmc_ref_"+year+"-"+month,null);
+  var result={year:year,month:month,errors:[],warnings:[],ok:[],
+    absentDuPDF:[],sansHoraire:[],sansDeparture:[],checkedAt:Date.now()};
+  if(!ref||!ref.rows){result.warnings.push({msg:"Aucune r\u00e9f\u00e9rence d'import pour ce mois"});return result;}
+  var days=getDays(year,month);
+  var importedIds=new Set(Object.keys(ref.rows));
+  // --- 1. V\u00e9rifier la correspondance planning \u2194 r\u00e9f\u00e9rence PDF ---
+  importedIds.forEach(function(empId){
+    var emp=A.employees.find(function(e){return e.id===empId;});
+    if(!emp){result.warnings.push({msg:"Employ\u00e9 "+empId+" introuvable dans la liste"});return;}
+    var refRow=ref.rows[empId];
+    var plRow=pl[empId]||{};
+    Object.keys(refRow).forEach(function(d){
+      var refCode=refRow[d];
+      var plCode=plRow[parseInt(d)]||"";
+      if(refCode!==plCode){
+        result.errors.push({
+          empId:empId,empName:emp.name,day:parseInt(d),
+          refCode:refCode,plCode:plCode,
+          msg:emp.name+" j"+d+": planning=\""+(plCode||"vide")+"\" \u2260 r\u00e9f\u00e9rence=\""+refCode+"\""
+        });
+      } else {
+        result.ok.push({empId:empId,day:d,code:refCode});
+      }
+    });
+  });
+  // --- 2. V\u00e9rifier que tous les employ\u00e9s actifs DEF_EMP ont horaire + ligne d\u00e9part ---
+  var allDepartureNames=new Set();
+  Object.keys(CHEFS_T).forEach(function(tid){(CHEFS_T[tid]||[]).forEach(function(n){allDepartureNames.add(n);});});
+  var defIds=new Set(DEF_EMP.map(function(e){return e.id;}));
+  A.employees.filter(function(emp){return isEmpActive(emp,year,month)&&defIds.has(emp.id);}).forEach(function(emp){
+    var isAbsent=!importedIds.has(emp.id);
+    if(isAbsent) result.absentDuPDF.push({id:emp.id,name:emp.name,team:emp.team});
+    var plRow=pl[emp.id]||{};
+    var hasDays=Object.keys(plRow).some(function(d){return !!plRow[d];});
+    // sansHoraire : uniquement les employés présents dans le PDF mais sans aucun code valide
+    if(!isAbsent&&!hasDays) result.sansHoraire.push({id:emp.id,name:emp.name,team:emp.team});
+    if(!allDepartureNames.has(emp.name)) result.sansDeparture.push({id:emp.id,name:emp.name,team:emp.team});
+  });
+  result.summary={
+    total:result.ok.length+result.errors.length,
+    correct:result.ok.length,
+    errors:result.errors.length,
+    absentDuPDF:result.absentDuPDF.length,
+    sansHoraire:result.sansHoraire.length,
+    sansDeparture:result.sansDeparture.length,
+    coverage:Math.round(result.ok.length/(result.ok.length+result.errors.length+.001)*100)
+  };
+  return result;
+}
