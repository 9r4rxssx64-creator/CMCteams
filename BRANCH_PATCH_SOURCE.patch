+(function migrateEmployees(){
+  var storedVer=parseInt(localStorage.getItem("cmc_dver")||"0");
+  var forceAll=storedVer<DATA_VER;
+  var changed=false;
+  DEF_EMP.forEach(function(def){
+    var e=A.employees.find(function(x){return x.id===def.id;});
+    if(!e){
+      // Ajouter l'employé manquant
+      A.employees.push(JSON.parse(JSON.stringify(def)));
+      changed=true;
+      return;
+    }
+    // Synchroniser les champs de DEF_EMP
+    // v9.108 — post/family/pinkComp ne sont PLUS écrasés à chaque reload :
+    //   - post : compétences admin + updates via import = source de vérité
+    //   - family : dérivée de post (via reassignAllFamiliesByCompSilent après migration)
+    //   - pinkComp : flag manuel admin (jamais dans DEF_EMP)
+    ["toMo","fromMo","family","chef","cdpShifts","team","post"].forEach(function(f){
+      if(f==="toMo"||f==="fromMo"){
+        if(forceAll){
+          // En force: appliquer la valeur DEF_EMP (null si absent dans DEF_EMP)
+          var defVal=def[f]!==undefined?def[f]:null;
+          if(JSON.stringify(e[f])!==JSON.stringify(defVal)){e[f]=defVal;changed=true;}
+        } else if(e[f]===undefined){
+          var defVal2=def[f]!==undefined?def[f]:null;
+          if(defVal2!==null){e[f]=defVal2;changed=true;}
+        }
+      } else if(f==="post"||f==="family"){
+        // v9.108 — NE PAS écraser si l'employé a déjà une valeur (admin ou import a pu la modifier)
+        // Seulement initialiser si absent, ou force complet
+        if(e[f]===undefined||e[f]===null||(f==="post"&&!e[f])){
+          if(def[f]!==undefined){e[f]=def[f];changed=true;}
+        } else if(forceAll&&def[f]!==undefined&&JSON.stringify(e[f])!==JSON.stringify(def[f])){
+          e[f]=def[f];changed=true;
+        }
+      } else {
+        // chef/team/cdpShifts : toujours synchroniser
+        if(def[f]!==undefined&&JSON.stringify(e[f])!==JSON.stringify(def[f])){
+          e[f]=def[f];changed=true;
+        }
+      }
+    });
+  });
+  if(changed) ls("cmc_e",A.employees);
+  if(forceAll){
+    // Effacer le cache des indices de départ (CI) pour forcer recalcul
+    for(var _y=2025;_y<=2028;_y++){for(var _m=0;_m<12;_m++){localStorage.removeItem("cmc_ci_"+_y+"_"+_m);}}
+    // Réinitialiser les équipes depuis DEF_TEAMS (ajoute roulettes r1-r13, CMC c1-c13)
+    A.teams=JSON.parse(JSON.stringify(DEF_TEAMS));
+    ls("cmc_t",A.teams);
+    localStorage.setItem("cmc_dver",String(DATA_VER));
+    // Effacer TOUS les overrides existants (peuvent contenir le mauvais SEED auto-charge)
+    // Exception : si un vrai import existe (cmc_ref_) → conserver les donnees
+    Object.keys(A.overrides).forEach(function(k){
+      if(!localStorage.getItem("cmc_ref_"+k)){
+        delete A.overrides[k];
+      }
+    });
+    // v8.52 : Plus de SEED pré-chargé — tout vide jusqu'à l'import
+    // Effacer tout override existant basé sur le SEED (données synthétiques)
+    (function(){
+      var _ref2026=localStorage.getItem("cmc_ref_2026-3");
