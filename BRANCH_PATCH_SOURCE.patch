+function runAudit(y,m){
+  y=y||A.year;m=m||A.month;
+  var key=y+"-"+m;
+  var pl=(function(){var tmp=A.year,tm=A.month;A.year=y;A.month=m;var r=gpl();A.year=tmp;A.month=tm;return r;})();
+  var ref=lg("cmc_ref_"+key,null);
+  var importedIds=ref&&ref.rows?new Set(Object.keys(ref.rows)):new Set();
+  // Noms importes depuis le PDF (pour suggestions de correspondance)
+  var importedNames=[];
+  if(ref&&ref.rows){
+    importedIds.forEach(function(eid){
+      var emp=A.employees.find(function(e){return e.id===eid;});
+      if(emp)importedNames.push(emp.name);
+    });
+  }
+  // Lignes de depart
+  var allDepartureNames=new Set();
+  Object.keys(CHEFS_T).forEach(function(tid){(CHEFS_T[tid]||[]).forEach(function(n){allDepartureNames.add(n);});});
+  var defIds=new Set(DEF_EMP.map(function(e){return e.id;}));
+  var results={absentDuPDF:[],sansHoraire:[],sansDeparture:[],ok:0,hasImport:importedIds.size>0};
+  A.employees.filter(function(emp){return isEmpActive(emp,y,m)&&defIds.has(emp.id);}).forEach(function(emp){
+    var plRow=pl[emp.id]||{};
+    var hasDays=Object.keys(plRow).some(function(d){return !!plRow[d];});
+    var codes=Object.values(plRow);
+    var codesSummary=codes.slice(0,10).join(' ');
+    // Absent du PDF
+    if(importedIds.size>0&&!importedIds.has(emp.id)){
+      // Chercher noms similaires dans la liste des importes
+      var suggestions=[];
+      if(ref&&ref.rows){
+        var allImportedEmps=[];
+        importedIds.forEach(function(eid){var e=A.employees.find(function(x){return x.id===eid;});if(e)allImportedEmps.push(e.name);});
+        allImportedEmps.forEach(function(n){
+          if(_strSim(emp.name,n)>0.55)suggestions.push(n);
+        });
+      }
+      results.absentDuPDF.push({id:emp.id,name:emp.name,team:emp.team,
+        hasDays:false,codesSummary:'',suggestions:suggestions}); // toujours vide sans import
+    } else {
+      // OK : présent dans l'import avec données
+      results.ok++;
+    }
+    if(!allDepartureNames.has(emp.name)){
+      results.sansDeparture.push({id:emp.id,name:emp.name,team:emp.team});
+    }
+  });
+  return results;
+}
