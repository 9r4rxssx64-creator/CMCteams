+function reassignAllFamiliesByCompSilent(){
+  var count={baccara:0,roulettes:0,cmc:0,unchanged:0,changed:0};
+  A.employees.forEach(function(e){
+    if(e.visitor)return;
+    var newFam=deduceFamilyFromComp(e.post,!!e.pinkComp);
+    if(!newFam||newFam===e.family){count.unchanged++;return;}
+    e.family=newFam;
+    count[newFam]=(count[newFam]||0)+1;
+    count.changed++;
+  });
+  if(count.changed>0)ls("cmc_e",A.employees);
+  return count;
+}
