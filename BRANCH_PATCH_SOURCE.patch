+// v9.45 \u2014 Expert Planning : d\u00e9tection des conflits de repos conventionnels
+// Retourne un tableau d'avertissements pour le mois courant
+// R\u00e8gle SBM art.17.5 : min 1 jour repos/semaine, normalement 2j cons\u00e9cutifs, min 10j/6 semaines
+// v9.46 \u2014 m\u00e9moisation par (y,m,ovSignature) pour \u00e9viter ~23K ops par render
+var _conflictCache=null,_conflictCacheKey=null;
+function _invalidateConflictCache(){_conflictCache=null;_conflictCacheKey=null;}
+function detectRepoConflicts(y,m){
+  // Cache key inclut une signature des overrides (taille JSON) qui change \u00e0 toute modif
+  var ov=(A.overrides||{})[y+"-"+m]||{};
+  var sig;
+  try{sig=JSON.stringify(ov).length;}catch(e){sig=Object.keys(ov).length;}
+  var cacheKey=y+"-"+m+"-"+A.employees.length+"-"+sig;
+  if(_conflictCacheKey===cacheKey&&_conflictCache)return _conflictCache;
+  var conflicts=[];
+  // v9.46 : gpl(y,m) propre au lieu d'IIFE qui mute A.year
+  var pl=gpl(y,m);
+  var daysInMonth=getDays(y,m);
+  A.employees.forEach(function(emp){
+    if(!isEmpActive(emp,y,m))return;
+    var row=pl[emp.id]||{};
+    // Compte les repos (R, RH) et travail par semaine (7 jours glissants)
+    var totalWork=0,totalRepo=0,emptyDays=0;
+    for(var d=1;d<=daysInMonth;d++){
+      var c=(row[d]||"").toUpperCase().trim();
+      if(!c){emptyDays++;continue;}
+      if(c==="R"||c==="RH")totalRepo++;
+      else if(/^\d/.test(c))totalWork++;
+    }
+    // Règle 1 : Convention SBM art.17.5 — min 10j repos / 6 semaines ≈ 5j repos / mois
+    if(totalWork>0&&totalRepo<Math.ceil(daysInMonth/7)){
+      conflicts.push({emp:emp,type:"repos_insuffisant",msg:emp.name+" : seulement "+totalRepo+" repos sur "+daysInMonth+"j ("+totalWork+" jours travaill\u00e9s)",severity:"high"});
+    }
+    // R\u00e8gle 2 : d\u00e9tecter 7+ jours cons\u00e9cutifs sans repos
+    var consec=0,maxConsec=0;
+    for(var d2=1;d2<=daysInMonth;d2++){
+      var c2=(row[d2]||"").toUpperCase().trim();
+      if(/^\d/.test(c2)){consec++;if(consec>maxConsec)maxConsec=consec;}
+      else if(c2==="R"||c2==="RH")consec=0;
+    }
+    if(maxConsec>=7){
+      conflicts.push({emp:emp,type:"max_jours_consec",msg:emp.name+" : "+maxConsec+" jours cons\u00e9cutifs de travail sans repos",severity:"critical"});
+    }
+    // Règle 3 : jours vides nombreux (data manquante)
+    if(emptyDays>daysInMonth/2){
+      conflicts.push({emp:emp,type:"donnees_manquantes",msg:emp.name+" : "+emptyDays+" jours non renseign\u00e9s",severity:"info"});
+    }
+    // Règle 4 : horaire de travail intercalé dans une période CP/AF/M (incohérence import)
+    var _absTypes={"CP":1,"AF":1,"M":1,"PAT":1,"MT":1,"AT":1,"FL":1,"ABS":1,"ABI":1,"CSS":1}; // v9.118 PAT=paternité ajouté
+    for(var d4=2;d4<daysInMonth;d4++){
+      var cPrev=(row[d4-1]||"").toUpperCase().trim();
+      var cCur=(row[d4]||"").toUpperCase().trim();
+      var cNext=(row[d4+1]||"").toUpperCase().trim();
+      if(_absTypes[cPrev]&&_absTypes[cNext]&&cCur&&!_absTypes[cCur]&&cCur!=="R"&&cCur!=="RH"&&/^\d/.test(cCur)){
+        conflicts.push({emp:emp,type:"horaire_dans_absence",msg:emp.name+" : "+cCur+" le jour "+d4+" entre "+cPrev+" (j"+(d4-1)+") et "+cNext+" (j"+(d4+1)+") \u2014 v\u00e9rifier",severity:"critical"});
+      }
+    }
+    // Règle 5 : longue série d'absences (CP/AF/M) > 15 jours → vérification RH
+    var _absCon=0,_absStart=0,_absType="";
+    for(var d5=1;d5<=daysInMonth;d5++){
+      var c5=(row[d5]||"").toUpperCase().trim();
+      if(_absTypes[c5]){
