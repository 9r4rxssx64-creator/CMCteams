+strong{color:#ffd700}
+</style></head><body>
+<pre style="white-space:pre-wrap">${md.replace(/</g,'&lt;')}</pre>
+</body></html>`;
+}
+
+export { RPM_BY_NICHE, PLATFORM_REVENUE };
