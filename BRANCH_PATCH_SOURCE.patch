+// Calcule un hash SHA-256 (Web Crypto API)
+async function _importHash(txt){
+  try{
+    var enc=new TextEncoder().encode(txt);
+    var buf=await crypto.subtle.digest("SHA-256",enc);
+    return Array.from(new Uint8Array(buf)).map(function(b){return b.toString(16).padStart(2,"0");}).join("").slice(0,24);
+  }catch(e){return null;}
+}
