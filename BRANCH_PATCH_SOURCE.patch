+    h+='<div style="margin-bottom:14px">'
+     +'<div style="display:flex;align-items:center;gap:6px;padding:6px 10px;background:'+tcc+'0c;border:1px solid '+tcc+'22;border-radius:6px 6px 0 0">'
+     +'<div style="width:6px;height:6px;border-radius:50%;background:'+tcc+'"></div>'
+     +'<span style="font-size:15px;font-weight:700;color:'+tcc+'">'+esc(team.name)+'</span>'
