+// Helper : retrouve le label officiel d'un code d'activité
+function bulletinCodeLabel(code){
+  if(!code)return"";
+  var found=null;
+  Object.keys(BULLETIN_CODES.categories).forEach(function(cat){
+    if(found)return;
+    var m=BULLETIN_CODES.categories[cat].find(function(c){return c.code===code;});
+    if(m)found=m.l;
+  });
+  return found||"";
+}
+// Helper : liste tous les codes à plat (pour recherche/autocomplétion)
+function bulletinAllCodes(){
+  var all=[];
+  Object.keys(BULLETIN_CODES.categories).forEach(function(cat){
+    BULLETIN_CODES.categories[cat].forEach(function(c){all.push({cat:cat,code:c.code,l:c.l});});
+  });
+  return all;
+}
