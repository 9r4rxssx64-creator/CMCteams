+// v9.86 — Throttle helper (limite fréquence d'appel d'une fonction coûteuse)
+function _throttle(fn,wait){
+  var last=0,t=null;
+  return function(){
+    var now=Date.now(),args=arguments,ctx=this;
+    var remaining=wait-(now-last);
+    if(remaining<=0){last=now;fn.apply(ctx,args);}
+    else{if(t)clearTimeout(t);t=setTimeout(function(){last=Date.now();fn.apply(ctx,args);t=null;},remaining);}
+  };
+}
