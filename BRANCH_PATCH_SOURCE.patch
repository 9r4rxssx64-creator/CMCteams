+// Force le rechargement complet depuis le serveur (contourne le cache iOS Safari)
+function forceRefresh(){
+  var go=function(){location.replace(location.href.split("?")[0]+"?v="+Date.now());};
+  var clearCaches=function(){
+    if(!('caches' in window))return Promise.resolve();
+    return caches.keys().then(function(ks){return Promise.all(ks.map(function(k){return caches.delete(k);}));});
+  };
+  if('serviceWorker' in navigator){
+    navigator.serviceWorker.getRegistrations().then(function(regs){
+      // Désinscrire tous les SW puis vider tous les caches, puis recharger
+      return Promise.all(regs.map(function(r){return r.unregister();}));
+    }).then(clearCaches).then(go).catch(function(){clearCaches().then(go).catch(go);});
+  } else {clearCaches().then(go).catch(go);}
+}
+// ── PHOTOS : upload / resize / stockage (v9.34, v9.41 compression auto) ────
+// Resize image via canvas avant stockage base64 (réduit Firebase RTDB)
+// v9.41 : compression progressive jusqu'\u00e0 rentrer dans budget si pr\u00e9cis\u00e9
+function _resizeImage(file,maxW,maxH,quality,cb,budgetBytes){
+  var reader=new FileReader();
+  reader.onload=function(ev){
+    var img=new Image();
+    img.onload=function(){
+      // Compression progressive : essais successifs (dim x qualit\u00e9) jusqu'\u00e0 rentrer
+      var attempts=[
+        {w:maxW,q:quality||0.85},
+        {w:Math.round(maxW*0.85),q:0.80},
+        {w:Math.round(maxW*0.70),q:0.75},
+        {w:Math.round(maxW*0.55),q:0.70},
+        {w:Math.round(maxW*0.40),q:0.65},
+        {w:Math.round(maxW*0.30),q:0.60}
+      ];
+      function tryAttempt(i){
+        if(i>=attempts.length){
+          cb(null,"Impossible de r\u00e9duire l'image suffisamment");
+          return;
+        }
+        var a=attempts[i];
+        var scale=Math.min(1,a.w/img.width,a.w/img.height);
+        var w=Math.round(img.width*scale),h=Math.round(img.height*scale);
+        var canvas=document.createElement("canvas");
+        canvas.width=w;canvas.height=h;
+        var ctx=canvas.getContext("2d");
+        ctx.fillStyle="#0a1408";ctx.fillRect(0,0,w,h);
+        ctx.drawImage(img,0,0,w,h);
+        try{
+          var dataUrl=canvas.toDataURL("image/jpeg",a.q);
+          // Si budget d\u00e9fini et d\u00e9pass\u00e9, on r\u00e9essaie avec compression plus forte
+          if(budgetBytes&&dataUrl.length>budgetBytes){
+            if(i<attempts.length-1){tryAttempt(i+1);return;}
+            // Dernier essai d\u00e9pass\u00e9 : on renvoie quand m\u00eame (best effort)
+          }
+          cb(dataUrl,null,{w:w,h:h,q:a.q,size:dataUrl.length});
+        }catch(e){
+          // Canvas OOM ou autre : essayer taille plus petite
+          if(i<attempts.length-1){tryAttempt(i+1);return;}
+          cb(null,e.message||"Canvas error");
+        }
+      }
+      tryAttempt(0);
+    };
+    img.onerror=function(){cb(null,"Image illisible");};
+    img.src=ev.target.result;
+  };
+  reader.onerror=function(){cb(null,"Lecture fichier \u00e9chou\u00e9e");};
+  reader.readAsDataURL(file);
+}
