+function _iaExecuteTool(toolName,input){
+  var isAdm=A.user&&A.user.id===AID;
+  try{
+    switch(toolName){
+      case"get_planning":{
+        var emp=A.employees.find(function(e){return e.id===(input.empId||"")||e.name.toUpperCase().indexOf((input.empId||"").toUpperCase())>=0;});
+        if(!emp)return"Employ\u00e9 non trouv\u00e9 : "+esc(input.empId);
+        var y=input.year||A.year,m=input.month!==undefined?input.month:A.month;
+        var pl=gpl(y,m);var codes=pl[emp.id]||{};var days=getDays(y,m);
+        var r=emp.name+" ("+emp.id+") \u2014 "+MFR[m]+" "+y+"\n";
+        for(var d=1;d<=days;d++)r+=d+":"+((codes[d]||"-"))+" ";
+        return r;
+      }
+      case"search_employees":{
+        // v9.115 — Fuzzy search (match exact + phonétique + Levenshtein) pour gérer fautes de frappe et phonétique italienne
+        var q=(input.query||"").toLowerCase().trim();
+        if(!q)return"Query vide";
+        // 1. Matches exacts (indexOf)
+        var exact=A.employees.filter(function(e){
+          return e.id.toLowerCase().indexOf(q)>=0
+            ||e.name.toLowerCase().indexOf(q)>=0
+            ||(A.reg[e.id]&&A.reg[e.id].prenom&&A.reg[e.id].prenom.toLowerCase().indexOf(q)>=0)
+            ||(A.reg[e.id]&&A.reg[e.id].nom&&A.reg[e.id].nom.toLowerCase().indexOf(q)>=0)
+            ||(A.reg[e.id]&&A.reg[e.id].email&&A.reg[e.id].email.toLowerCase().indexOf(q)>=0)
+            ||(e.team||"").toLowerCase().indexOf(q)>=0
+            ||(getFamLabel(e.family||"bj")).toLowerCase().indexOf(q)>=0;
+        });
+        // 2. Si aucun match, fuzzy via similarité caractères communs (gère Jacobi → GIACOBBI, Rossi → ROSI, etc.)
+        var res=exact;
+        if(!res.length){
+          function simScore(a,b){
+            if(!a||!b)return 0;
+            a=a.toLowerCase();b=b.toLowerCase();
+            // Normalisation : supprime accents, apostrophes, espaces multiples
+            var norm=function(s){return s.normalize?s.normalize("NFD").replace(/[\u0300-\u036f]/g,""):s;};
+            a=norm(a);b=norm(b);
+            // Retire les consonnes doubles (giacobbi→giacobi, rossi→rosi)
+            var simpl=function(s){return s.replace(/(.)\1+/g,"$1");};
+            var as=simpl(a),bs=simpl(b);
+            if(as===bs)return 1;
+            if(bs.indexOf(as)>=0||as.indexOf(bs)>=0)return 0.92;
+            // Compte caractères communs en séquence approximative
+            var common=0,bi=0;
+            for(var i=0;i<as.length;i++){
+              var idx=bs.indexOf(as[i],bi);
+              if(idx>=0){common++;bi=idx+1;}
+            }
+            return common/Math.max(as.length,bs.length);
+          }
+          var scored=A.employees.map(function(e){
+            var reg=A.reg[e.id]||{};
+            var best=Math.max(
+              simScore(q,e.name||""),
+              simScore(q,(e.name||"").split(" ")[0]),
+              simScore(q,reg.nom||""),
+              simScore(q,reg.prenom||"")
+            );
+            return{e:e,score:best};
+          }).filter(function(x){return x.score>=0.55;});
+          scored.sort(function(a,b){return b.score-a.score;});
+          res=scored.slice(0,10).map(function(x){return x.e;});
+        }
+        res=res.slice(0,20);
+        if(!res.length)return"Aucun employé trouvé pour '"+esc(input.query)+"'. Essayez une variante orthographique ou un matricule (U00xxx).";
+        var prefix=exact.length===0?"(Recherche floue appliquée car aucun match exact)\n":"";
+        return prefix+res.map(function(e){
+          var reg=A.reg[e.id]||{};
+          return e.id+" | "+e.name+(reg.prenom?" ("+reg.prenom+")":"")+" | Éq."+(e.team||"?")+" | "+getFamLabel(e.family||"bj")+(e.senior?" ★":"")+(e.chef?" Chef":"");
+        }).join("\n");
+      }
+      case"get_employee_info":{
+        var emp=A.employees.find(function(e){return e.id===input.empId;});
+        if(!emp)return"Employ\u00e9 non trouv\u00e9 : "+input.empId;
+        var reg=A.reg[emp.id]||{};
+        var role=emp.role?getRoleLabel(emp.role):"";
+        return JSON.stringify({id:emp.id,nom:emp.name,prenom:reg.prenom||"",equipe:emp.team,famille:getFamLabel(emp.family||"bj"),senior:!!emp.senior,chef:!!emp.chef,groupe:emp.groupe||"nd",role:role,email:reg.email||"",dateEntreeSbm:reg.dateEntreeSbm||"",dateEntreeJeux:reg.dateEntreeJeux||"",competences:emp.post||""},null,2);
+      }
+      case"get_stats":{
+        var emp=A.employees.find(function(e){return e.id===input.empId;});
+        if(!emp)return"Employ\u00e9 non trouv\u00e9";
+        var y=input.year||A.year,m=input.month!==undefined?input.month:A.month;
+        var st=calcStats(emp.id,{y:y,m:m});
+        return emp.name+" \u2014 "+MFR[m]+" "+y+":\n"+JSON.stringify({jours_travail:st.trav,heures:st.heures,repos:st.RH+st.R,conges:st.CP,maladie:st.M,formation:st.AF,nuits:st.nuits||0,coupures:st.coupures||0,weekEnds:st.weekEnds||0},null,2);
+      }
+      case"get_today_status":{
+        var today=new Date();var y=today.getFullYear(),m=today.getMonth(),d=today.getDate();
+        var pl=gpl(y,m);
+        var working=[],repos=[],absent=[];
+        A.employees.forEach(function(e){
+          var c=(pl[e.id]||{})[d]||"";
+          if(isWork(c))working.push(e.name+"("+c+")");
+          else if(c==="RH"||c==="R")repos.push(e.name);
+          else if(c)absent.push(e.name+"("+c+")");
+        });
+        return"Aujourd'hui "+d+" "+MFR[m]+" "+y+":\nEn service ("+working.length+") : "+working.join(", ")+"\nRepos ("+repos.length+") : "+repos.join(", ")+"\nAutre ("+absent.length+") : "+absent.join(", ");
+      }
+      case"find_game_rooms":{
+        var res=findSallesPourJeu(input.game,input.establishment||"all");
+        if(!res.length)return"Aucune salle pour "+esc(input.game);
+        return res.map(function(r){return r.etab.toUpperCase()+" \u2014 "+r.nom;}).join("\n");
+      }
+      case"search_convention":{
+        var q=(input.query||"").toLowerCase();
+        var arts=CONVENTION.articles.filter(function(a){return a.titre.toLowerCase().indexOf(q)>=0||a.contenu.toLowerCase().indexOf(q)>=0;});
+        var codes=bulletinAllCodes().filter(function(c){return c.code.toLowerCase().indexOf(q)>=0||c.l.toLowerCase().indexOf(q)>=0;});
+        var r="";
+        if(arts.length)r+="ARTICLES :\n"+arts.map(function(a){return"Art."+a.num+" "+a.titre+" \u2014 "+a.contenu.slice(0,200);}).join("\n")+"\n";
+        if(codes.length)r+="CODES PAIE :\n"+codes.map(function(c){return c.code+" = "+c.l;}).join("\n");
+        return r||"Aucun r\u00e9sultat pour '"+esc(input.query)+"'";
+      }
+      case"get_team_roster":{
+        var members=A.employees.filter(function(e){return e.team===input.teamId;});
+        if(!members.length)return"Aucun employ\u00e9 dans l'\u00e9quipe "+esc(input.teamId);
+        return"Equipe "+input.teamId+" ("+members.length+" membres) :\n"+members.map(function(e){return e.id+" "+e.name+(e.chef?" [Chef]":"")+(e.senior?" \u2605":"");}).join("\n");
+      }
+      case"get_conflicts":{
+        var y=input.year||A.year,m=input.month!==undefined?input.month:A.month;
+        try{var c=detectRepoConflicts(y,m);
+        if(!c||!c.length)return"Aucun conflit d\u00e9tect\u00e9 pour "+MFR[m]+" "+y;
+        return c.length+" alerte(s) :\n"+c.slice(0,15).map(function(a){return"["+a.severity+"] "+(a.emp?a.emp.name:"?")+" \u2014 "+a.msg;}).join("\n");
+        }catch(e){return"Erreur d\u00e9tection conflits : "+e.message;}
+      }
+      case"get_upload_requests":{
+        var pending=(A.uploadRequests||[]).filter(function(r){return r.status==="pending";});
+        if(!pending.length)return"Aucune demande en attente.";
+        return pending.length+" demande(s) en attente :\n"+pending.map(function(r){return r.empName+" \u2014 "+r.filename+" ("+r.category+") \u2014 "+new Date(r.ts).toLocaleString("fr-FR");}).join("\n");
+      }
+      // ADMIN ONLY
+      case"get_who_is_free":{
+        var y=input.year||A.year,m=input.month!==undefined?input.month:A.month,d=input.day;
+        var pl=gpl(y,m);
+        var free=[],working=[];
+        A.employees.forEach(function(e){
+          var c=(pl[e.id]||{})[d]||"";
+          if(!c||c==="RH"||c==="R"||c==="CP"||c==="M"||c==="AF"||c==="ABS")free.push(e.name+"("+(c||"non d\u00e9fini")+")");
+          else working.push(e.name);
+        });
+        return"Jour "+d+" "+MFR[m]+" "+y+":\nLibres ("+free.length+") : "+free.join(", ")+"\nEn service ("+working.length+")";
+      }
+      case"get_leave_balance":{
+        var emp=A.employees.find(function(e){return e.id===input.empId;});
