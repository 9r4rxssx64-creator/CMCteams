+// Helper : rechercher dans la convention
+function conventionSearch(query){
+  if(!query)return CONVENTION.articles;
+  var q=query.toLowerCase().trim();
+  return CONVENTION.articles.filter(function(a){
+    return String(a.num).indexOf(q)>=0||a.titre.toLowerCase().indexOf(q)>=0||a.contenu.toLowerCase().indexOf(q)>=0||a.cat.indexOf(q)>=0;
+  });
+}
+// Helper : récupère jours de congé pour un événement familial
+function conventionCongeJours(evenement){
+  if(!evenement)return 0;
+  var e=evenement.toLowerCase();
+  var match=CONVENTION.congesFamiliaux.find(function(c){return c.evenement.toLowerCase().indexOf(e)>=0||e.indexOf(c.evenement.toLowerCase().split(" ")[0])>=0;});
+  return match?match.jours:0;
+}
