+  if(!A.overrides[k][empId])A.overrides[k][empId]={};
+  var oldVal=A.overrides[k][empId][day]||"";
+  A.overrides[k][empId][day]=newVal;
+  ls("cmc_ov",A.overrides);
+  var label=labelAction||("Planning "+day+"/"+(month+1)+" "+empId+" : "+oldVal+"\u2192"+newVal);
+  _pushUndo(label,
+    function(){A.overrides[k][empId][day]=oldVal;ls("cmc_ov",A.overrides);},
+    function(){A.overrides[k][empId][day]=newVal;ls("cmc_ov",A.overrides);}
+  );
+}
