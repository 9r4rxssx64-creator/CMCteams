+// Loading skeleton (blocs gris pulsants)
+function skeleton(lines,width){
+  lines=lines||3;var w=width||"100%";
+  var h='<div style="padding:12px">';
+  for(var i=0;i<lines;i++){
+    var lw=(i===lines-1)?"60%":"100%";
+    h+='<div class="skel skel-line" style="width:'+lw+';height:14px;margin-bottom:'+(i<lines-1?10:0)+'px"></div>';
+  }
+  return h+'</div>';
+}
+// Confirmation riche avec texte à taper pour confirmer (anti-accident)
+function confirmDanger(message,confirmWord){
+  confirmWord=confirmWord||"OUI";
+  var input=prompt(message+"\n\n\u26a0\ufe0f Pour confirmer, tapez : "+confirmWord);
+  if(input===null)return false;
+  return input.trim().toUpperCase()===confirmWord.toUpperCase();
+}
