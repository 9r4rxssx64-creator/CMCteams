+// \u2500\u2500 Parser planning CMC (items avec coordonn\u00e9es X,Y) \u2500\u2500\u2500\u2500\u2500
+function parseCMCPlanningFromItems(allItems, year, month){
+  var days=getDays(year,month);
+  var validCodesArr=Object.keys(CODES);
+
+  // \u2500\u2500 1. Grouper les items par ligne Y (tol\u00e9rance \u00b15px) \u2500\u2500
+  var sorted=allItems.slice().sort(function(a,b){return a.y-b.y||a.x-b.x;});
+  var rows=[];
+  var curY=null;
+  sorted.forEach(function(item){
+    if(curY===null||Math.abs(item.y-curY)>5){
+      rows.push([]);curY=item.y;
+    }
+    rows[rows.length-1].push(item);
+  });
+
+  // \u2500\u2500 2. Trouver la ligne des jours (1-31) \u2500\u2500
+  var dayRow=null;
+  rows.forEach(function(row){
+    var nums=row.filter(function(i){var n=parseInt(i.txt);return !isNaN(n)&&n>=1&&n<=31&&i.txt===String(n);});
+    if(nums.length>=20) dayRow=nums; // au moins 20 jours trouv\u00e9s sur une ligne
+  });
+  // Fallback: prendre la ligne avec le plus de chiffres 1-31
+  if(!dayRow){
+    var best=0;
+    rows.forEach(function(row){
+      var nums=row.filter(function(i){var n=parseInt(i.txt);return !isNaN(n)&&n>=1&&n<=31&&i.txt===String(n);});
+      if(nums.length>best){best=nums.length;dayRow=nums;}
+    });
+  }
+  if(!dayRow||dayRow.length<5) return buildDebugCSV(allItems,"Ligne jours non trouv\u00e9e");
+
+  // Position X de chaque jour
+  var dayPos={};
+  dayRow.forEach(function(i){dayPos[parseInt(i.txt)]=i.x;});
+
+  // Tol\u00e9rance X = moiti\u00e9 espacement entre jours cons\u00e9cutifs
+  var dNums=Object.keys(dayPos).map(Number).sort(function(a,b){return a-b;});
+  var xTol=15;
+  if(dNums.length>=2){
+    var gaps=[];
+    for(var i=1;i<Math.min(dNums.length,8);i++){
+      var g=dayPos[dNums[i]]-dayPos[dNums[i-1]];
+      if(g>2&&g<80) gaps.push(g);
+    }
+    if(gaps.length) xTol=Math.round(gaps.reduce(function(a,b){return a+b;})/gaps.length*0.55);
+  }
+
+  function xToDay(x){
+    var best=null,bestDist=xTol*1.8;
+    dNums.forEach(function(d){
+      var dist=Math.abs(dayPos[d]-x);
+      if(dist<bestDist){bestDist=dist;best=d;}
+    });
+    return best;
+  }
+
+  // \u2500\u2500 3. Trouver les lignes d'employ\u00e9s \u2500\u2500
+  // Chaque employ\u00e9 appara\u00eet comme NOM + PRENOM sur une ligne
+  var empLines=[]; // {empName, y, rowIdx}
+  rows.forEach(function(row,ri){
+    var rawLineText=row.map(function(i){return i.txt;}).join(" ").toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
+    // Detecter l'etoile rouge juste apres le nom : marque "55+ ans" uniquement.
+    // v9.40 : ne force plus family=roulettes ni chef=true (compatible avec baccara/autres).
+    var lineHasStar=/[\u2605\u2606\u2b50]/.test(rawLineText);
+    var lineText=rawLineText.replace(/[\u2605\u2606\u2b50]/g," ");
+    A.employees.forEach(function(emp){
+      var eName=emp.name.toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
+      var parts=eName.split(" ");
+      // Match si le NOM de famille appara\u00eet dans cette ligne
+      var nomMatch=parts[0]&&lineText.includes(parts[0]);
+      var prenomMatch=parts.length>1&&parts[1]&&lineText.includes(parts[1][0]);
+      if(nomMatch&&(parts.length===1||prenomMatch)){
+        var existing=empLines.find(function(e){return e.empName===emp.name&&Math.abs(e.y-(row[0]||{y:0}).y)<20;});
+        if(!existing) empLines.push({empName:emp.name,y:(row[0]||{y:0}).y,rowIdx:ri});
+        // Etoile = marquer seulement senior, sans toucher \u00e0 family ni chef
+        if(lineHasStar&&!emp.senior){
+          emp.senior=true;ls("cmc_e",A.employees);fbWrite("cmc_e",A.employees);
+        }
+      }
+    });
+  });
+
+  if(empLines.length===0) return buildDebugCSV(allItems,"Aucun employ\u00e9 trouv\u00e9. Noms dans le PDF: "+allItems.slice(0,20).map(function(i){return i.txt;}).join(","));
+
+  // \u2500\u2500 4. D\u00e9tecter le s\u00e9parateur (trait noir = grand \u00e9cart vertical entre groupes d'employ\u00e9s) \u2500\u2500
+  var empYsSorted=empLines.map(function(e){return e.y;}).sort(function(a,b){return a-b;});
+  // Detecter TOUS les separateurs significatifs (traits rouges/noirs entre equipes et equipes miroirs)
+  var separators=[];
+  if(empYsSorted.length>2){
+    var avgGap=(empYsSorted[empYsSorted.length-1]-empYsSorted[0])/(empYsSorted.length-1);
+    for(var gi=1;gi<empYsSorted.length;gi++){
+      var gap=empYsSorted[gi]-empYsSorted[gi-1];
+      if(gap>avgGap*1.8) separators.push((empYsSorted[gi]+empYsSorted[gi-1])/2);
+    }
+  }
+  // Retourne le numero de segment pour une position Y
+  function getSegment(y){
+    var seg=0;
+    for(var si=0;si<separators.length;si++){if(y>separators[si])seg=si+1;}
+    return seg;
+  }
+
+  // Planning vide par employe
+  var planning={};
+  empLines.forEach(function(e){if(!planning[e.empName])planning[e.empName]={};});
+
+  // Index CDP : items contenant "CDP" ou "*" pour les rep\u00e9rer par position
+  var cdpItems=[];
+  allItems.forEach(function(item){
+    var t=item.txt.trim().toUpperCase();
+    if(t==="CDP"||t==="*"||t==="C.D.P") cdpItems.push({x:item.x,y:item.y});
+  });
+
+  allItems.forEach(function(item){
+    var raw=item.txt.trim().toUpperCase().replace(/['']/g,"'");
+    // Normaliser tiret\u2192slash pour codes horaires : "16-3"\u2192"16/3"
+    var code=raw.replace(/^(\d{1,2})-(\d{1,2})(\*?)$/,'$1/$2$3');
+    code=code.replace(/\s*\/\s*/,'/');
+    code=code.replace(/CDP$/,'*');
+    if(CDP_MAP[code]){
+      var hasCdpNear=false;
+      cdpItems.forEach(function(ci){if(Math.abs(ci.x-item.x)<20&&Math.abs(ci.y-item.y)<12)hasCdpNear=true;});
+      if(hasCdpNear) code=CDP_MAP[code];
+    }
+    if(validCodesArr.indexOf(code)<0) return;
+
+    var day=xToDay(item.x);
+    if(!day||day<1||day>days) return;
+
+    // Trouver l'employ\u00e9 le plus proche — DANS LE M\u00caMME GROUPE (m\u00eame c\u00f4t\u00e9 du trait noir)
+    var bestEmp=null,bestDist=30;
+    empLines.forEach(function(el){
+      // Rester dans le meme segment (entre deux separateurs)
+      if(getSegment(item.y)!==getSegment(el.y)) return;
+      var d=Math.abs(el.y-item.y);
+      if(d<bestDist){bestDist=d;bestEmp=el.empName;}
+    });
+    if(bestEmp){
+      var empObj=A.employees.find(function(e){return e.name===bestEmp;});
+      // Auto-upgrade CDP selon profil employe
+      if(empObj&&!code.endsWith("*")&&CDP_MAP[code]&&empObj.cdpShifts&&empObj.cdpShifts.indexOf(code)>=0){
+        code=CDP_MAP[code];
+      }
+      planning[bestEmp][day]=code;
+    }
+  });
+
+  // \u2500\u2500 5. Construire CSV \u2500\u2500
+  var found=Object.keys(planning).filter(function(n){return Object.keys(planning[n]).length>0;});
+  if(!found.length) return buildDebugCSV(allItems,"Codes trouv\u00e9s mais pas associ\u00e9s. DayPos: "+JSON.stringify(dayPos).slice(0,100));
+
+  var daysArr=(function(n){var a=[];for(var i=0;i<n;i++)a.push(i+1);return a;})(days);
+  var header="NOM,"+daysArr.join(",");
+  var csvLines=[header];
+  found.forEach(function(name){
+    var row=[name];
+    for(var di=1;di<=days;di++){row.push(planning[name][di]||"");}
+    csvLines.push(row.join(","));
+  });
+  return csvLines.join("\n");
+}
+
+
+function buildDebugCSV(items,reason){
+  var lines=["# DEBUG: "+reason];
+  // Afficher les 40 premiers items distincts
+  var seen={};
+  items.slice(0,200).forEach(function(i){if(!seen[i.txt]&&i.txt.length<20){seen[i.txt]=true;lines.push("x="+i.x+",y="+i.y+",txt="+i.txt);}});
+  return lines.join("\n");
+}
