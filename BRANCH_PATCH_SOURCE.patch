+function _cleanOldImportBackups(keepLast){
+  var keys=[];
+  for(var k in localStorage){if(k.indexOf("cmc_auto_backup_import_")===0)keys.push(k);}
+  keys.sort();
+  while(keys.length>keepLast){localStorage.removeItem(keys.shift());}
+}
+function _cleanOldBackups(keepLast){
+  var keys=[];
+  for(var k in localStorage){if(k.indexOf("cmc_auto_backup_")===0)keys.push(k);}
+  keys.sort(); // alphabétique = chronologique (YYYY-MM-DD)
+  while(keys.length>keepLast){
+    var old=keys.shift();
+    try{localStorage.removeItem(old);}catch(e){}
+  }
+}
