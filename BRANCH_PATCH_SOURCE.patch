+// --- AUDIT AUTONOME ---
+// Similarite entre deux chaines (pour detecter noms proches)
+function _strSim(a,b){
+  a=a.toUpperCase();b=b.toUpperCase();
+  if(a===b)return 1;
+  if(a.length<2||b.length<2)return 0;
+  var bigrams={};
+  for(var i=0;i<a.length-1;i++){var bg=a.slice(i,i+2);bigrams[bg]=(bigrams[bg]||0)+1;}
+  var inter=0;
+  for(var i=0;i<b.length-1;i++){var bg=b.slice(i,i+2);if(bigrams[bg]>0){inter++;bigrams[bg]--;}}
+  return 2*inter/(a.length+b.length-2);
+}
+
+// v9.78 — Distance de Levenshtein (nombre d'\u00e9ditions pour transformer a en b)
+// Utilis\u00e9e pour matching noms proches avec fautes de frappe ou accents normalis\u00e9s
+function _levenshtein(a,b){
+  a=a.toUpperCase();b=b.toUpperCase();
+  if(a===b)return 0;
+  if(!a.length)return b.length;
+  if(!b.length)return a.length;
+  var prev=new Array(b.length+1),cur=new Array(b.length+1);
+  for(var j=0;j<=b.length;j++)prev[j]=j;
+  for(var i=1;i<=a.length;i++){
+    cur[0]=i;
+    for(var j=1;j<=b.length;j++){
+      var cost=a[i-1]===b[j-1]?0:1;
+      cur[j]=Math.min(cur[j-1]+1,prev[j]+1,prev[j-1]+cost);
+    }
+    var tmp=prev;prev=cur;cur=tmp;
+  }
+  return prev[b.length];
+}
+
+// v9.78 — Version simple de Metaphone (code phon\u00e9tique pour homophones)
+// Ex: "DUPONT" et "DUPOND" donnent le m\u00eame code
+function _metaphone(s){
+  if(!s)return "";
+  s=s.toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"").replace(/[^A-Z]/g,"");
+  if(!s)return "";
+  // Sons finaux nets
+  s=s.replace(/ENT$/,"AN").replace(/ET$/,"E").replace(/S$/,"").replace(/D$/,"T");
+  // Groupes phon\u00e9tiques courants fran\u00e7ais
+  s=s.replace(/PH/g,"F").replace(/CH/g,"S").replace(/QU/g,"K").replace(/CK/g,"K");
+  s=s.replace(/AU|EAU|AUX|EAUX|O/g,"O").replace(/AI|EI|ET|AY|EY/g,"E").replace(/OU|OUX/g,"U");
+  s=s.replace(/AN|EN|AM|EM/g,"AN").replace(/ON|OM/g,"ON").replace(/IN|IM|AIN|EIN|UN|UM/g,"IN");
+  // Consonnes \u00e9quivalentes
+  s=s.replace(/C([EI])/g,"S$1").replace(/G([EI])/g,"J$1");
+  s=s.replace(/C/g,"K").replace(/Q/g,"K").replace(/Y/g,"I").replace(/W/g,"V").replace(/X/g,"KS").replace(/Z/g,"S");
+  // Compresser les doublons
+  s=s.replace(/(.)\1+/g,"$1");
+  // D\u00e9duplications sons
+  return s.slice(0,8);
+}
+
+// v9.78 — Match multi-strat\u00e9gie pour un nom : retourne candidate + confidence
+// Combine bigram (ressemblance lettres), Levenshtein (\u00e9ditions), et Metaphone (phon\u00e9tique)
+function _matchName(query,candidates){
+  var q=query.toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
+  if(!q||!candidates||!candidates.length)return null;
+  var qMeta=_metaphone(q);
+  var best=null,bestScore=0;
+  candidates.forEach(function(c){
+    var cn=c.name||c;
+    var cnNorm=cn.toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
+    if(q===cnNorm)return best={cand:c,score:1,method:"exact"};
+    var bg=_strSim(q,cnNorm);
+    var lev=_levenshtein(q,cnNorm);
+    var levScore=lev<=Math.max(1,Math.floor(cnNorm.length*0.15))?1-lev/cnNorm.length:0;
+    var metaMatch=qMeta&&_metaphone(cnNorm)===qMeta?0.9:0;
+    var score=Math.max(bg,levScore,metaMatch);
+    if(score>bestScore){bestScore=score;best={cand:c,score:score,method:bg>=score?"bigram":levScore>=score?"levenshtein":"metaphone",lev:lev};}
+  });
+  return best&&best.score>=0.7?best:null;
+}
