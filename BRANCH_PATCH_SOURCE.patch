+  var snap=lg("cmc_import_snap_"+key,null);
+  if(!snap){toast("Aucun snapshot disponible pour "+MFR[im]+" "+iy,"err");return;}
+  var label=snap.monthLabel||key;
+  var ageMin=Math.floor((Date.now()-snap.ts)/60000);
+  var ageLabel=ageMin<60?ageMin+" min":(Math.floor(ageMin/60))+"h"+(ageMin%60).toString().padStart(2,"0");
+  if(!confirm("\u26a0\ufe0f ROLLBACK : restaurer l'\u00e9tat du planning "+label+" d'il y a "+ageLabel+" ?\n\nCela annule toutes les modifications depuis le dernier import.\n\nContinuer ?"))return;
+  // Restaurer overrides du mois
+  A.overrides[key]=snap.overrides;
+  ls("cmc_ov",A.overrides);
+  // Restaurer A.employees si différent (emps ajoutés depuis seront perdus)
+  if(snap.employeesSnapshot&&snap.employeesSnapshot.length!==A.employees.length){
+    if(confirm("L'effectif a chang\u00e9 : "+snap.employeesCount+" avant \u2192 "+A.employees.length+" apr\u00e8s.\n\nRestaurer aussi la liste des employ\u00e9s (cela supprimera les cr\u00e9ations r\u00e9centes) ?")){
+      A.employees=snap.employeesSnapshot;
+      ls("cmc_e",A.employees);
+    }
+  }
+  // Restaurer refData et verif
+  if(snap.refData)ls("cmc_ref_"+key,snap.refData);
+  else try{localStorage.removeItem("cmc_ref_"+key);fbWrite("cmc_ref_"+key,null);}catch(e){}
+  if(snap.verif)ls("cmc_verif_"+key,snap.verif);
+  else try{localStorage.removeItem("cmc_verif_"+key);fbWrite("cmc_verif_"+key,null);}catch(e){}
+  // Audit
+  _audit("import_rollback",AID,label,"snapshot "+ageLabel,"restaur\u00e9");
+  // Supprimer le snapshot (usage unique)
+  try{localStorage.removeItem("cmc_import_snap_"+key);}catch(e){}
