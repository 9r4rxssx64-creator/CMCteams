+var LOI_1103={
+  titre:"Loi n\u00b0 1.103 du 12 juin 1987",
+  objet:"relative \u00e0 l'exploitation des jeux dans les maisons de jeux du territoire de la Principaut\u00e9 de Monaco",
+  publication:"Journal Officiel du 26/06/1987",
+  modifiee:"Loi n\u00b0 1.261 du 23/12/2002",
+  sections:[
+    {num:"I",titre:"Dispositions g\u00e9n\u00e9rales (art. 1-5)",articles:[
+      {num:1,titre:"Monopole SBM",contenu:"L'exploitation des jeux de hasard dans les maisons de jeux est accord\u00e9e par le Prince sous forme de concession. La SBM (Soci\u00e9t\u00e9 des Bains de Mer) est le concessionnaire exclusif."},
+      {num:2,titre:"Types de jeux autoris\u00e9s",contenu:"Les jeux autoris\u00e9s sont d\u00e9termin\u00e9s par Ordonnance Souveraine (OS n\u00b0 8.929). Tout nouveau jeu doit \u00eatre autoris\u00e9 par Arr\u00eat\u00e9 Minist\u00e9riel."},
+      {num:3,titre:"Conditions d'exploitation",contenu:"Les conditions g\u00e9n\u00e9rales d'exploitation (horaires, mises, acc\u00e8s) sont fix\u00e9es par Arr\u00eat\u00e9 Minist\u00e9riel."},
+      {num:4,titre:"Surveillance",contenu:"La surveillance des jeux est exerc\u00e9e par un commissaire sp\u00e9cial et des fonctionnaires de la S\u00fbret\u00e9 Publique."},
+      {num:5,titre:"Interdiction de jeu",contenu:"Les r\u00e9sidents mon\u00e9gasques de nationalit\u00e9 mon\u00e9gasque sont interdits de jouer dans les casinos de la Principaut\u00e9."}
+    ]},
+    {num:"II",titre:"Personnel (art. 6-9)",articles:[
+      {num:6,titre:"Agr\u00e9ment administratif",contenu:"Tout employ\u00e9 des jeux doit obtenir un agr\u00e9ment d\u00e9livr\u00e9 par le Directeur de la S\u00fbret\u00e9 Publique apr\u00e8s enqu\u00eate de moralit\u00e9. L'agr\u00e9ment est r\u00e9vocable."},
+      {num:7,titre:"Conditions d'emploi",contenu:"\u00c2ge minimum : 21 ans. Casier judiciaire vierge. Formation professionnelle requise."},
+      {num:8,titre:"Interdictions personnels",contenu:"Les employ\u00e9s des jeux ne peuvent : jouer dans les casinos de Monaco, pr\u00eater de l'argent aux joueurs, accepter des pourboires en dehors du tronc commun, communiquer des informations sur les joueurs."},
+      {num:9,titre:"Sanctions disciplinaires",contenu:"Le retrait de l'agr\u00e9ment entra\u00eene la cessation imm\u00e9diate des fonctions. Les infractions sont sanctionn\u00e9es p\u00e9nalement."}
+    ]},
+    {num:"III",titre:"Fonctionnement (art. 10-15)",articles:[
+      {num:10,titre:"Horaires",contenu:"Les heures d'ouverture et de fermeture sont fix\u00e9es par Arr\u00eat\u00e9 Minist\u00e9riel. Les tables ne peuvent ouvrir que si au moins un commissaire est pr\u00e9sent."},
+      {num:11,titre:"Mises",contenu:"Les limites de mises (minimum et maximum) sont fix\u00e9es par le concessionnaire et approuv\u00e9es par Arr\u00eat\u00e9 Minist\u00e9riel."},
+      {num:12,titre:"Contr\u00f4le des recettes",contenu:"Les recettes brutes des jeux sont soumises \u00e0 un pr\u00e9l\u00e8vement au profit de l'\u00c9tat mon\u00e9gasque (AM 96-166)."},
+      {num:13,titre:"Acc\u00e8s des salles",contenu:"L'acc\u00e8s est interdit aux mineurs de moins de 18 ans (CMC) ou 21 ans (CDP). Pi\u00e8ce d'identit\u00e9 obligatoire."}
+    ]},
+    {num:"IV",titre:"Dispositions p\u00e9nales (art. 16-20)",articles:[
+      {num:16,titre:"Infractions",contenu:"Exploitation ill\u00e9gale de jeux : emprisonnement de 6 mois \u00e0 3 ans + amende. Triche : emprisonnement de 1 \u00e0 5 ans."},
+      {num:18,titre:"Tricherie",contenu:"Toute fraude, tricherie ou manipulation des jeux est punie d'emprisonnement et d'amende. Les complices sont \u00e9galement poursuivis."}
+    ]},
+    {num:"V",titre:"Dispositions finales (art. 21-23)",articles:[
+      {num:21,titre:"Entr\u00e9e en vigueur",contenu:"La pr\u00e9sente loi entre en vigueur le 1er juillet 1987. Les r\u00e8glements d'application (OS et AM) seront pris dans les 3 mois."}
+    ]}
+  ]
+};
