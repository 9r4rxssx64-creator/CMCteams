+  input.type="file";
+  input.accept="image/*,application/pdf,.doc,.docx,.txt,.rtf,.xls,.xlsx,.csv,.odt,.ods,.ppt,.pptx,.zip";
+  input.multiple=true;
+  input.onchange=function(ev){
+    var files=Array.from(ev.target.files||[]);if(!files.length)return;
+    var total=_docsTotalSize();
+    // Filtrer les non-images > DOC_MAX_SIZE (les images seront compress\u00e9es auto).
+    // Pour les non-images, proposer compression externe si trop gros.
+    var tooBigNonImg=files.filter(function(f){return f.type.indexOf("image/")!==0&&f.size>DOC_MAX_SIZE;});
+    if(tooBigNonImg.length){
+      var _limit=Math.round(DOC_MAX_SIZE/1024/1024);
+      toast("Non compressible (max "+_limit+" MB) : "+tooBigNonImg.map(function(f){return f.name+" ("+(Math.round(f.size/1024/1024*10)/10)+" MB)";}).join(", "),"err");
+      files=files.filter(function(f){return f.type.indexOf("image/")===0||f.size<=DOC_MAX_SIZE;});
+      if(!files.length)return;
+    }
+    // Warn si total cumul\u00e9 proche de la limite Firebase
+    if(total+files.reduce(function(s,f){return s+f.size;},0)>DOC_TOTAL_WARN){
+      if(!confirm("\u26a0 Capacit\u00e9 presque atteinte ("+Math.round((total+files.reduce(function(s,f){return s+f.size;},0))/1024/1024)+" MB).\nContinuer l'import ?"))return;
+    }
+    var remaining=files.length;
+    var okCount=0;
+    toast("\u23f3 Import de "+files.length+" fichier"+(files.length>1?"s":"")+"...");
+    files.forEach(function(file){
+      var isImg=file.type.indexOf("image/")===0;
+      var process=function(dataUrl){
+        A.docs=A.docs||[];
+        A.docs.push({
+          id:"d"+Date.now()+Math.random().toString(36).slice(2,7),
+          name:file.name,
+          cat:cat||"autres",
+          mime:file.type||"application/octet-stream",
+          size:dataUrl.length,
+          dataUrl:dataUrl,
+          uploadedAt:Date.now(),
+          uploadedBy:AID,
+          notes:"",
+          shared:isShared
+        });
+        okCount++;
+        remaining--;
+        if(remaining===0){
+          ls("cmc_docs",A.docs);
+          _audit("doc_upload",AID,"","","Import "+okCount+" doc(s), cat: "+(cat||"autres")+(isShared?" [PARTAG\u00c9]":" [priv\u00e9]"));
+          toast("\u2705 "+okCount+" fichier"+(okCount>1?"s":"")+" import\u00e9"+(okCount>1?"s":"")+(isShared?" (partag\u00e9)":""));
+          dc();
+        }
+      };
+      if(isImg){
+        // Compression progressive auto : budget 90% de DOC_MAX_SIZE (marge base64)
+        var budget=Math.round(DOC_MAX_SIZE*0.9);
+        _resizeImage(file,2000,2000,0.88,function(dataUrl,err,info){
+          if(err||!dataUrl){remaining--;toast("Erreur "+file.name+" : "+(err||"?"),"err");return;}
+          process(dataUrl);
+        },budget);
