+// ── STATISTIQUES COMPLÈTES PAR EMPLOYÉ ───────────────────────────────────────
+// Calcule les heures de travail d'un code horaire (ex: "22/6" → 8h)
+// Table des shifts à durée spécifique (coupures, exceptions)
+// Par défaut : calcul continu (fin - début). Ici : overrides pour les coupures.
+var CODE_HOURS={
+  "16/3":9,"16/3*":9,   // Coupure : 16h-20h (4h) + 22h-3h (5h) = 9h
+  "22/6":8,"19/4":9,"20/5":9,"16/22":6,"14/19":5,"15/19":4,"14/20":6,
+  "20/5*":9,"19/4*":9,"16/22*":6  // CDP : mêmes heures que les shifts de base
+};
+function codeHours(code){
+  if(!code)return 0;
+  if(CODE_HOURS[code]!==undefined)return CODE_HOURS[code];
+  var m=code.replace(/[*']/g,"").match(/^(\d{1,2})\/(\d{1,2})$/);
+  if(!m)return 0;
+  var s=parseInt(m[1]),e=parseInt(m[2]);
+  if(e<s)e+=24; // shift traverse minuit
+  return e-s;
+}
+// Stats complètes pour un employé sur une plage (mois ou année)
+// scope = {y:2026, m:3} pour un mois, {y:2026} pour une année, {} pour carrière
+function calcStats(empId,scope){
+  var st={
+    trav:0,heures:0,CDP:0,
+    nuits:0,coupures:0,weekEnds:0,  // v9.45 \u2014 shifts difficiles pour \u00e9quilibrage
+    RH:0,R:0,repos:0,
+    CP:0,M:0,AF:0,RRT:0,HC:0,PRT:0,PAT:0,conv:0,autre:0,
+    total:0,parCode:{},parMois:{}
+  };
+  var yStart,yEnd,mStart,mEnd;
+  if(scope.y!==undefined){
+    yStart=yEnd=scope.y;
+    if(scope.m!==undefined){mStart=mEnd=scope.m;}
+    else{mStart=0;mEnd=11;}
+  } else {
+    // Carrière : balayer toutes les années dans overrides + archive
+    var years={};
+    Object.keys(A.overrides||{}).forEach(function(k){var y=parseInt(k.split("-")[0]);if(!isNaN(y))years[y]=1;});
+    var arch=lg("cmc_stats_archive",{});
+    if(arch[empId])Object.keys(arch[empId]).forEach(function(y){years[parseInt(y)]=1;});
+    var ys=Object.keys(years).map(Number).sort();
+    if(!ys.length)return st;
+    yStart=ys[0];yEnd=ys[ys.length-1];
+    mStart=0;mEnd=11;
+  }
+  for(var y=yStart;y<=yEnd;y++){
+    for(var mo=mStart;mo<=mEnd;mo++){
+      var ov=(A.overrides||{})[y+"-"+mo]||{};
+      var row=ov[empId]||{};
+      var dayCount=getDays(y,mo);
+      var moKey=y+"-"+(mo<9?"0":"")+(mo+1);
+      for(var d=1;d<=dayCount;d++){
+        // Normalisation robuste : trim, String(), accept\u00e9 m\u00eame si casse/espaces
+        var raw=String(row[d]||"").trim();
+        if(!raw)continue;
+        st.total++;
+        st.parCode[raw]=(st.parCode[raw]||0)+1;
+        if(!st.parMois[moKey])st.parMois[moKey]={trav:0,heures:0,repos:0,abs:0};
+        // base = code normalis\u00e9 sans suffixes CDP/conv (majuscules + strip * ')
+        var base=raw.toUpperCase().replace(/[*']/g,"").trim();
+        if(base==="RH"){st.RH++;st.repos++;st.parMois[moKey].repos++;}
+        else if(base==="R"){st.R++;st.repos++;st.parMois[moKey].repos++;}
+        else if(base==="CP"){st.CP++;st.parMois[moKey].abs++;}
+        else if(base==="M"){st.M++;st.parMois[moKey].abs++;}
+        else if(base==="AF"){st.AF++;st.parMois[moKey].abs++;}
+        else if(base==="RRT"){st.RRT++;st.parMois[moKey].abs++;}
+        else if(base==="HC"){st.HC++;}
+        else if(base==="PRT"){st.PRT++;}
+        else if(base==="PAT"){st.PAT++;}
+        // Codes non pr\u00e9sents dans CODES historiquement mais utiles pour bulletins SBM
+        else if(base==="FL"||base==="FTP"||base==="FTR"||base==="RFT"){st.AF++;st.parMois[moKey].abs++;}
+        else if(base==="AT"||base==="MT"||base==="ABS"||base==="ABI"||base==="ABP"){st.M++;st.parMois[moKey].abs++;}
+        else if(/^\d/.test(base)){
+          // Code horaire (travail)
+          if(raw.indexOf("'")>=0){st.conv++;st.parMois[moKey].abs++;}
+          else{
+            st.trav++;
+            var h=codeHours(raw);
+            st.heures+=h;
+            st.parMois[moKey].trav++;
+            st.parMois[moKey].heures+=h;
+            if(raw.indexOf("*")>=0)st.CDP++;
+            // v9.45 \u2014 comptage shifts difficiles pour \u00e9quilibrage
+            // Nuits : shifts qui traversent minuit (20/5, 22/6, 19/4 etc.)
+            if(raw.indexOf("22/6")===0||raw.indexOf("20/5")===0||raw.indexOf("19/4")===0)st.nuits++;
+            // Coupures : 16/3 traverse 20h-22h
+            if(raw.indexOf("16/3")===0)st.coupures++;
+            // Week-ends travaill\u00e9s (samedi=6, dimanche=0)
+            var _dow=new Date(y,mo,d).getDay();
+            if(_dow===0||_dow===6)st.weekEnds++;
+          }
+        }
+        else{
+          // Code inconnu/non cat\u00e9goris\u00e9 \u2014 trac\u00e9 pour diagnostic
+          st.autre++;
+          st.parMois[moKey].abs++;
+        }
+      }
+    }
+  }
+  return st;
+}
+// Archive un snapshot carrière d'un employé (permanent, survit à sa sortie)
+function archiveEmpStats(empId){
+  if(!A.user||A.user.id!==AID)return;
+  var arch=lg("cmc_stats_archive",{});
+  if(!arch[empId])arch[empId]={};
+  var emp=A.employees.find(function(e){return e.id===empId;});
+  var reg=A.reg[empId]||{};
+  // Trouver toutes les années où l'employé a des données
+  var years={};
+  Object.keys(A.overrides||{}).forEach(function(k){
+    var parts=k.split("-");
+    var y=parseInt(parts[0]);
+    if(!isNaN(y)&&A.overrides[k]&&A.overrides[k][empId])years[y]=1;
+  });
+  Object.keys(years).forEach(function(y){
+    arch[empId][y]={
+      stats:calcStats(empId,{y:parseInt(y)}),
+      name:emp?emp.name:(reg.nom?reg.nom+" "+(reg.prenom?reg.prenom[0]:""):empId),
+      team:emp?emp.team:"",
+      role:emp?emp.role||"":"",
+      family:emp?emp.family||"":"",
+      archivedAt:Date.now()
+    };
+  });
+  ls("cmc_stats_archive",arch);
+}
+function archiveAllEmps(){
+  if(!A.user||A.user.id!==AID)return;
