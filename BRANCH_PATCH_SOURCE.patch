+// Usage: _lazyLoad('SALON_PHOTOS', () => eval("window.SALON_PHOTOS")) → retourne promise
+var _lazyCache={};
+function _lazyLoad(name,loader){
+  if(_lazyCache[name])return Promise.resolve(_lazyCache[name]);
+  return Promise.resolve().then(function(){
+    var v=loader();
+    _lazyCache[name]=v;
+    return v;
+  });
+}
