+// v9.83 — UNDO/REDO GLOBAL pour admin (stack de 50 actions)
+// Chaque mutation admin pousse un snapshot inversible dans la stack
+var _undoStack=[],_redoStack=[],_UNDO_MAX=50;
+function _pushUndo(label,undoFn,redoFn){
+  if(!A.user||A.user.id!==AID)return;
+  _undoStack.push({ts:Date.now(),label:label||"Action",undo:undoFn,redo:redoFn});
+  if(_undoStack.length>_UNDO_MAX)_undoStack.shift();
+  _redoStack=[]; // nouvelle action efface la stack redo
+}
+function undoAdmin(){
+  if(!A.user||A.user.id!==AID){toast("Undo admin uniquement","err");return;}
+  if(!_undoStack.length){toast("Rien \u00e0 annuler","info");return;}
+  var entry=_undoStack.pop();
+  try{
+    entry.undo();
+    _redoStack.push(entry);
+    _audit("undo",AID,entry.label,"","annul\u00e9");
+    toast("\u21a9 Annul\u00e9 : "+entry.label);
+    dc();
+  }catch(e){toast("Erreur undo: "+e.message,"err");}
+}
+function redoAdmin(){
+  if(!A.user||A.user.id!==AID){toast("Redo admin uniquement","err");return;}
+  if(!_redoStack.length){toast("Rien \u00e0 r\u00e9tablir","info");return;}
+  var entry=_redoStack.pop();
+  try{
+    entry.redo();
+    _undoStack.push(entry);
+    _audit("redo",AID,entry.label,"","r\u00e9tabli");
+    toast("\u21aa R\u00e9tabli : "+entry.label);
+    dc();
+  }catch(e){toast("Erreur redo: "+e.message,"err");}
+}
