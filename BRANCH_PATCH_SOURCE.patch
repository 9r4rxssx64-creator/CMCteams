+    refData:lg("cmc_ref_"+key,null),
+    verif:lg("cmc_verif_"+key,null),
+    sourceLength:(sourceText||"").length
+  };
+  try{localStorage.setItem("cmc_import_snap_"+key,JSON.stringify(snap));}catch(e){console.warn("snapshot save:",e);}
+  // Hash async (n'attend pas)
+  _importHash(sourceText||"").then(function(h){
+    if(h){try{
+      var s=lg("cmc_import_snap_"+key,null);
+      if(s){s.sourceHash=h;localStorage.setItem("cmc_import_snap_"+key,JSON.stringify(s));}
