+// Employé propose un document : ouvre file picker + compression + soumission
+function employeeProposeUpload(category){
+  if(!A.user){toast("Connectez-vous","err");return;}
+  if(A.user.id===AID){toast("En tant qu'admin vous pouvez uploader directement","info");return;}
+  if(!isUploadEnabled()){toast("\u26a0 Les uploads sont actuellement d\u00e9sactiv\u00e9s par l'admin","warn");return;}
+  var input=document.createElement("input");
+  input.type="file";
+  input.accept="image/*,application/pdf,.doc,.docx,.txt,.rtf,.xls,.xlsx,.csv,.odt,.ods,.ppt,.pptx";
+  input.onchange=function(ev){
+    var file=(ev.target.files||[])[0];
+    if(!file)return;
+    if(file.size>DOC_MAX_SIZE&&file.type.indexOf("image/")!==0){
+      toast("Fichier trop gros (max "+Math.round(DOC_MAX_SIZE/1024/1024)+" MB)","err");
+      return;
