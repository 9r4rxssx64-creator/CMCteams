+function exportPlanningCSV(){
+  var pl=gpl(),days=getDays(A.year,A.month);
+  var rows=[];
+  // v9.47 : en-t\u00eate enrichi pour usage paie
+  var header=["Matricule","Nom","Equipe","Famille","Groupe","Role"];
+  for(var d=1;d<=days;d++) header.push(String(d));
+  header.push(
+    "Jours_Travail","Heures_Total","Jours_Repos",
+    "RH","R","CP","M","AF","RRT","HC","CDP",
+    "Nuits","Coupures","Week_Ends","Autre"
+  );
+  rows.push(header.join(";"));
+  // Trier : famille puis \u00e9quipe puis nom
+  var emps=A.employees.filter(function(emp){return isEmpActive(emp,A.year,A.month);});
+  emps.sort(function(a,b){
+    var fo=["bj","roulettes","baccara","cmc"];
+    var fa=fo.indexOf(a.family||"bj"),fb=fo.indexOf(b.family||"bj");
+    if(fa!==fb) return fa-fb;
+    if(a.team!==b.team) return String(a.team).localeCompare(String(b.team));
+    return a.name.localeCompare(b.name);
+  });
+  // Helper CSV-safe : \u00e9chapper guillemets et wrapping
+  var _csv=function(v){
+    var s=String(v==null?"":v);
+    if(s.indexOf(";")>=0||s.indexOf('"')>=0||s.indexOf("\n")>=0){
+      return '"'+s.replace(/"/g,'""')+'"';
+    }
+    return s;
+  };
+  emps.forEach(function(emp){
+    var st=calcStats(emp.id,{y:A.year,m:A.month});
+    var row=[
+      _csv(emp.id),
+      _csv(emp.name),
+      _csv(emp.team),
+      _csv(getFamLabel(emp.family||"bj")),
+      _csv(emp.groupe||""),
+      _csv(emp.role||"")
+    ];
+    for(var d=1;d<=days;d++){
+      row.push(_csv((pl[emp.id]||{})[d]||""));
+    }
+    row.push(
+      st.trav,st.heures,st.repos,
+      st.RH,st.R,st.CP,st.M,st.AF,st.RRT,st.HC,st.CDP,
+      st.nuits,st.coupures,st.weekEnds,st.autre
+    );
+    rows.push(row.join(";"));
+  });
+  var bom="\uFEFF"; // BOM UTF-8 pour Excel
+  var blob=new Blob([bom+rows.join("\n")],{type:"text/csv;charset=utf-8"});
+  var url=URL.createObjectURL(blob);
+  var a=document.createElement("a");
+  a.href=url;
+  a.download="planning-paie-"+(MFR[A.month]||"").toLowerCase()+"-"+A.year+".csv";
+  document.body.appendChild(a);a.click();document.body.removeChild(a);
+  URL.revokeObjectURL(url);
+  _audit("export_paie_csv",AID,"","",emps.length+" employ\u00e9s \u2014 "+MFR[A.month]+" "+A.year);
+  toast("\u2705 CSV paie export\u00e9 \u2014 "+emps.length+" employ\u00e9s \u00b7 "+header.length+" colonnes");
+}
