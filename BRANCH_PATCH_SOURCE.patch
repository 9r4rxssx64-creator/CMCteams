+// Parse la chaîne de poste PDF ("BRTP+E.") → tableau de codes ["B","R","T","P+","E"]
+function parseCompetences(post){
+  if(!post)return[];
+  var s=post.replace(/[.\s]/g,"").toUpperCase();
+  var knownIds=COMPETENCES.map(function(c){return c.id;});
+  var res=[],i=0;
+  while(i<s.length){
+    if(s[i]==="+"||s[i]==="-"){i++;continue;}
+    var cid;
+    if(s[i+1]==="+"){cid=s[i]+"+";i+=2;}
+    else{cid=s[i];i++;}
+    if(knownIds.indexOf(cid)>=0)res.push(cid); // filtre les chars inconnus
+  }
+  return res;
+}
