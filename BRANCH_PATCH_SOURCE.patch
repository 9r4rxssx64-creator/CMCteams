+  if(ref&&ref.rows){
+    var _famCnt={bj:0,roulettes:0,baccara:0,cmc:0,autre:0};
+    Object.keys(ref.rows).forEach(function(eid){
+      var e=A.employees.find(function(x){return x.id===eid;});
+      if(e)_famCnt[e.family||"autre"]=(_famCnt[e.family||"autre"]||0)+1;
+    });
+    lines.push("--- SECTIONS IMPORTEES ---");
+    lines.push("  Jeux am\u00e9ricains : "+_famCnt.bj+" employ\u00e9(s)");
+    lines.push("  Jeux europ\u00e9en   : "+_famCnt.roulettes+" employ\u00e9(s)");
+    lines.push("  Baccara          : "+_famCnt.baccara+" employ\u00e9(s)");
+    lines.push("  Groupe ouvert    : "+_famCnt.cmc+" employ\u00e9(s)");
+    if(_famCnt.autre)lines.push("  Autre            : "+_famCnt.autre+" employ\u00e9(s)");
