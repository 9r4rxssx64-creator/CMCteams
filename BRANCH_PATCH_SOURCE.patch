+// v9.86 — IndexedDB helper (stockage >5MB pour photos/backups lourds)
+// Fallback localStorage si IndexedDB indisponible
+var _idbDB=null;
+function _idbInit(){
+  if(_idbDB)return Promise.resolve(_idbDB);
+  return new Promise(function(resolve){
+    try{
+      if(!window.indexedDB)return resolve(null);
+      var req=indexedDB.open("cmcteams",1);
+      req.onupgradeneeded=function(){
+        var db=req.result;
+        if(!db.objectStoreNames.contains("kv"))db.createObjectStore("kv");
+      };
+      req.onsuccess=function(){_idbDB=req.result;resolve(_idbDB);};
+      req.onerror=function(){resolve(null);};
+    }catch(e){resolve(null);}
+  });
+}
+function _idbSet(key,value){
+  return _idbInit().then(function(db){
+    if(!db){try{localStorage.setItem(key,JSON.stringify(value));return true;}catch(e){return false;}}
+    return new Promise(function(resolve){
+      var tx=db.transaction("kv","readwrite");
+      tx.objectStore("kv").put(value,key);
+      tx.oncomplete=function(){resolve(true);};
+      tx.onerror=function(){resolve(false);};
+    });
+  });
+}
+function _idbGet(key){
+  return _idbInit().then(function(db){
+    if(!db){try{var v=localStorage.getItem(key);return v?JSON.parse(v):null;}catch(e){return null;}}
+    return new Promise(function(resolve){
+      var tx=db.transaction("kv","readonly");
+      var req=tx.objectStore("kv").get(key);
+      req.onsuccess=function(){resolve(req.result||null);};
+      req.onerror=function(){resolve(null);};
+    });
+  });
+}
+function _idbDelete(key){
+  return _idbInit().then(function(db){
+    if(!db){try{localStorage.removeItem(key);return true;}catch(e){return false;}}
+    return new Promise(function(resolve){
+      var tx=db.transaction("kv","readwrite");
+      tx.objectStore("kv").delete(key);
+      tx.oncomplete=function(){resolve(true);};
+      tx.onerror=function(){resolve(false);};
+    });
+  });
+}
+function _idbSize(){
+  return _idbInit().then(function(db){
+    if(!db||!navigator.storage||!navigator.storage.estimate)return {quota:null,usage:null};
+    return navigator.storage.estimate().then(function(est){return{quota:est.quota,usage:est.usage,pct:est.quota?(est.usage/est.quota*100).toFixed(1):null};});
+  });
+}
