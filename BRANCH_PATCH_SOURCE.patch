+// v9.78 — Validation sommes d'un import : compte jours travaill\u00e9s/repos/cong\u00e9s
+// et d\u00e9tecte \u00e9cart > tol\u00e9rance avec une r\u00e9f\u00e9rence pr\u00e9vue
+function _validateImportSums(overrides,expectedEmps,totalDays){
+  var counts={work:0,rest:0,conge:0,maladie:0,unknown:0,codes:{}};
+  Object.keys(overrides||{}).forEach(function(eid){
+    var days=overrides[eid]||{};
+    Object.keys(days).forEach(function(d){
+      var c=days[d]||"";
+      if(!c)return;
+      counts.codes[c]=(counts.codes[c]||0)+1;
+      if(c==="RH"||c==="R"||c==="RRT")counts.rest++;
+      else if(c==="CP")counts.conge++;
+      else if(c==="M"||c==="AT"||c==="MT")counts.maladie++;
+      else if(typeof CODES!=="undefined"&&CODES[c])counts.work++;
+      else counts.unknown++;
+    });
+  });
+  // V\u00e9rifications de coh\u00e9rence
+  var totalEmps=Object.keys(overrides||{}).length;
+  var totalCells=counts.work+counts.rest+counts.conge+counts.maladie+counts.unknown;
+  var expectedCells=totalEmps*(totalDays||31);
+  var coverage=expectedCells?totalCells/expectedCells:0;
+  var warnings=[];
+  if(coverage<0.7)warnings.push("Couverture faible: "+(coverage*100).toFixed(0)+"% ("+totalCells+"/"+expectedCells+" cellules)");
+  if(counts.unknown>0)warnings.push(counts.unknown+" cellules avec codes inconnus");
+  if(counts.rest===0&&totalEmps>5)warnings.push("Aucun jour de repos d\u00e9tect\u00e9 \u2014 suspect");
+  if(expectedEmps&&Math.abs(totalEmps-expectedEmps)/expectedEmps>0.1)warnings.push("Effectif d\u00e9vie: "+totalEmps+" vs "+expectedEmps+" attendus");
+  return{counts:counts,totalEmps:totalEmps,totalCells:totalCells,expectedCells:expectedCells,coverage:coverage,warnings:warnings};
+}
