+// Détecte les doublons employés et propose un nettoyage interactif
+function detectDuplicates(){
+  if(!A.user||A.user.id!==AID)return;
+  var byName={};
+  function normName(n){return (n||"").trim().toUpperCase().replace(/\s+/g," ");}
+  A.employees.forEach(function(e){
+    var k=normName(e.name);
+    if(!byName[k])byName[k]=[];
+    byName[k].push(e);
+  });
+  var dups=[];
+  Object.keys(byName).forEach(function(k){if(byName[k].length>1)dups.push({name:k,emps:byName[k]});});
+  if(!dups.length){
+    toast("\u2705 Aucun doublon d\u00e9tect\u00e9 ("+A.employees.length+" employ\u00e9s uniques)");
+    return;
+  }
+  var msg="\u26a0 "+dups.length+" doublon(s) d\u00e9tect\u00e9(s) :\n\n";
+  dups.forEach(function(d){
+    msg+="\u2022 "+d.name+" \u2014 "+d.emps.length+" entr\u00e9es :\n";
+    d.emps.forEach(function(e){
+      var hasData=A.passwords[e.id]||A.reg[e.id];
+      var hasOv=Object.keys(A.overrides||{}).some(function(mo){return (A.overrides[mo]||{})[e.id]&&Object.keys(A.overrides[mo][e.id]).length>0;});
+      msg+="   - "+e.id+(hasData?" \u2713pw":"")+(hasOv?" \u2713planning":"")+"\n";
+    });
+    msg+="\n";
+  });
+  msg+="Nettoyer automatiquement ? (garde l'entr\u00e9e DEF_EMP ou celle avec le plus de donn\u00e9es)";
+  if(!confirm(msg))return;
+  // Nettoyage
+  var defIds={};DEF_EMP.forEach(function(d){defIds[d.id]=true;});
+  var kept=[],removed=0;
+  A.employees.forEach(function(e){
+    var k=normName(e.name);
+    if(!byName[k]||byName[k].length<=1){kept.push(e);return;}
+    // Choisir le meilleur représentant du groupe
+    var group=byName[k];
+    var best=group.find(function(x){return defIds[x.id];})
+            ||group.find(function(x){return A.passwords[x.id]||A.reg[x.id];})
+            ||group[0];
+    if(e===best&&kept.indexOf(e)<0){
+      // Migrer les données des autres vers best
+      group.forEach(function(other){
+        if(other.id===best.id)return;
+        if(A.passwords[other.id]&&!A.passwords[best.id])A.passwords[best.id]=A.passwords[other.id];
+        delete A.passwords[other.id];
+        if(A.reg[other.id]&&!A.reg[best.id])A.reg[best.id]=A.reg[other.id];
+        delete A.reg[other.id];
+        Object.keys(A.overrides||{}).forEach(function(mo){
+          var ov=A.overrides[mo];
+          if(ov[other.id]&&!ov[best.id])ov[best.id]=ov[other.id];
+          delete ov[other.id];
+        });
+        removed++;
+      });
+      kept.push(e);
+      byName[k]=[best]; // marquer comme traité
+    }
+  });
+  A.employees=kept;
+  ls("cmc_e",A.employees);ls("cmc_pw",A.passwords);ls("cmc_reg",A.reg);ls("cmc_ov",A.overrides);
+  _audit("dedup_manual",AID,"","",removed+" doublon(s) nettoy\u00e9(s)");
+  toast("\u2705 "+removed+" doublon(s) supprim\u00e9(s), donn\u00e9es migr\u00e9es");
+  dc();
+}
