+// === Lazy-load PDF.js (v9.49) ===
+// Charge PDF.js depuis cdnjs SEULEMENT quand l'admin importe un PDF.
+// Avant v9.49, le script de 500 KB \u00e9tait charg\u00e9 au d\u00e9marrage pour
+// tous les employ\u00e9s m\u00eame s'ils n'utilisaient jamais l'import.
+var _pdfJsLoading=null;
+function loadPdfJs(){
+  if(typeof pdfjsLib!=="undefined")return Promise.resolve();
+  if(_pdfJsLoading)return _pdfJsLoading;
+  _pdfJsLoading=new Promise(function(resolve,reject){
+    var s=document.createElement("script");
+    s.src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js";
+    s.crossOrigin="anonymous";
+    s.referrerPolicy="no-referrer";
+    s.onload=function(){resolve();};
+    s.onerror=function(){_pdfJsLoading=null;reject(new Error("PDF.js n'a pas pu \u00eatre charg\u00e9 (v\u00e9rifiez votre connexion)"));};
+    document.head.appendChild(s);
+  });
+  return _pdfJsLoading;
+}
+
+// === Extraction PDF structurée via PDF.js ===
+function _extractPdfLines(file,onDone,onErr){
+  loadPdfJs().then(function(){
+    if(typeof pdfjsLib==="undefined"){onErr("PDF.js indisponible");return;}
+    pdfjsLib.GlobalWorkerOptions.workerSrc="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
+    _doExtractPdfLines(file,onDone,onErr);
+  }).catch(function(e){onErr(e.message||"Erreur chargement PDF.js");});
+}
+function _doExtractPdfLines(file,onDone,onErr){
+  var rd=new FileReader();
+  rd.onload=function(ev){
+    var arr=new Uint8Array(ev.target.result);
+    pdfjsLib.getDocument({data:arr}).promise.then(function(pdf){
+      var allLines=[],pg=1;
+      function nextPage(){
+        if(pg>pdf.numPages){onDone(allLines.join("\n"));return;}
+        pdf.getPage(pg).then(function(page){
+          // v9.67 — Extraire texte + couleurs pour détecter jours rouges (affluence)
+          Promise.all([page.getTextContent(),page.getOperatorList()]).then(function(results){
+            var tc=results[0],ops=results[1];
+            // Construire une map des couleurs texte + fond pour chaque item texte
+            var _colorMap={},_bgColorMap={},_curColor=null,_curBgColor=null,_textIdx=0;
+            var OPS=pdfjsLib.OPS;
+            var _lastFillBeforeRect=null;
+            for(var oi=0;oi<ops.fnArray.length;oi++){
+              if(ops.fnArray[oi]===OPS.setFillRGBColor){
+                var rgb=ops.argsArray[oi];
+                _curColor=rgb?{r:Math.round(rgb[0]*255),g:Math.round(rgb[1]*255),b:Math.round(rgb[2]*255)}:null;
+                _lastFillBeforeRect=_curColor;
+              }
+              // Rectangles remplis = fonds de cellules
+              if(ops.fnArray[oi]===OPS.constructPath||ops.fnArray[oi]===OPS.fill){
+                _curBgColor=_lastFillBeforeRect;
+              }
+              if(ops.fnArray[oi]===OPS.showText||ops.fnArray[oi]===OPS.showSpacedText){
+                _colorMap[_textIdx]=_curColor;
+                _bgColorMap[_textIdx]=_curBgColor;
+                _textIdx++;
+              }
+            }
+            var TOL=3,rowMap={};
+            var _ti=0;
+            tc.items.forEach(function(it){
+              if(it.str===undefined){return;} // marked content
+              var y=Math.round(it.transform[5]/TOL)*TOL;
+              var x=it.transform[4];
+              var t=(it.str||"").replace(/\s+/g," ").trim();
+              var col=_colorMap[_ti]||null;
+              var bgCol=_bgColorMap[_ti]||null;
+              _ti++;
+              if(!t)return;
+              if(!rowMap[y])rowMap[y]=[];
+              rowMap[y].push({x:x,t:t,color:col,bg:bgCol});
+            });
+            // Détecter jours rouges (affluence) + fonds orange/rouge (CDP)
+            if(!window._pdfRedDays)window._pdfRedDays=[];
+            if(!window._pdfCdpCells)window._pdfCdpCells=[];
+            var ys=Object.keys(rowMap).map(Number).sort(function(a,b){return b-a;});
+            ys.forEach(function(y){
+              var items=rowMap[y].slice().sort(function(a,b){return a.x-b.x;});
+              items.forEach(function(it){
+                var num=parseInt(it.t);
+                // Jours rouges (texte rouge = affluence, en-tête)
+                if(num>=1&&num<=31&&it.color&&it.color.r>180&&it.color.g<100&&it.color.b<100){
+                  if(window._pdfRedDays.indexOf(num)<0)window._pdfRedDays.push(num);
+                }
+                // Fond orange/rouge = CDP (Café de Paris)
+                // Orange : R>200, G entre 80-180, B<100
+                // Fond orange/rouge = CDP (Café de Paris)
+                if(it.bg&&it.bg.r>200&&it.bg.g>=80&&it.bg.g<=180&&it.bg.b<100){
+                  var _shiftCode=it.t.replace(/[*']/g,"").trim();
+                  if(CODES[_shiftCode]||CODES[_shiftCode+"*"]){
+                    window._pdfCdpCells.push({y:y,x:it.x,code:_shiftCode,type:"cdp"});
+                  }
+                }
+                // Fond vert = Formation (AF)
+                if(it.bg&&it.bg.g>150&&it.bg.r<150&&it.bg.b<150){
+                  window._pdfCdpCells.push({y:y,x:it.x,code:it.t.trim(),type:"af"});
+                }
+                // Fond rose = CP / Congé
+                if(it.bg&&it.bg.r>200&&it.bg.g>150&&it.bg.b>180&&it.bg.r>it.bg.g){
+                  window._pdfCdpCells.push({y:y,x:it.x,code:it.t.trim(),type:"cp"});
+                }
+                // Fond violet foncé = RH (repos hebdo)
+                if(it.bg&&it.bg.r>80&&it.bg.r<160&&it.bg.b>150&&it.bg.g<100){
+                  window._pdfCdpCells.push({y:y,x:it.x,code:it.t.trim(),type:"rh"});
+                }
+                // Fond violet clair / lavande = R (repos)
