+name: Auto-deploy agent sur Vercel
+
+# Quand un commit modifie tools/agent/* → redéploie automatiquement sur Vercel
+# (Vercel le fait déjà nativement si l'intégration GitHub est active,
+#  ce workflow est un backup explicite)
+
+on:
+  push:
+    branches: [main]
+    paths:
+      - 'tools/agent/**'
+      - 'tools/integrations/**'
+
+jobs:
+  notify:
+    runs-on: ubuntu-latest
+    steps:
+      - name: Notify via Telegram
+        if: env.TELEGRAM_BOT_TOKEN != ''
+        env:
+          TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
+          TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}
+        run: |
+          if [ -n "$TELEGRAM_BOT_TOKEN" ]; then
+            curl -s "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage" \
+              -d "chat_id=$TELEGRAM_CHAT_ID" \
+              -d "text=🚀 Agent KDMC : nouveau commit poussé. Vercel redéploie..."
+          fi
