+    if(!hasPw){results.nonInscrits.push(emp);return;} // priorit\u00e9 1
+    if(!reg.email){results.sansEmail.push(emp);}
+    if(!reg.photo){results.sansPhoto.push(emp);}
+    var lastLogin=lastLoginByUid[emp.id];
+    if(lastLogin&&(now-lastLogin)>30*DAY){
+      results.inactifs30j.push({emp:emp,lastLogin:lastLogin,days:Math.floor((now-lastLogin)/DAY)});
+    }
+  });
+  return results;
