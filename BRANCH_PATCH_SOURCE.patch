+// Recherche employé par nom+prénom complets.
+// Stratégie : A.reg (exact) → source (prefixe stocké) → DEF_EMP (prefixe stocké)
+// Les entrées DEF_EMP sont au format "NOM IN" (1-2 initiales).
+// On vérifie que les initiales stockées sont un PRÉFIXE du prénom saisi.
+function findEmpByName(nom,prenom,src){
+  nom=nom.toUpperCase().trim(); prenom=prenom.toUpperCase().trim();
+  if(!nom||!prenom)return null;
+  var nomBase=nom+" ";
+  // 1. A.reg — identité complète enregistrée
+  var rk=Object.keys(A.reg).find(function(k){var r=A.reg[k];return r&&r.nom&&r.nom.toUpperCase()===nom&&r.prenom&&r.prenom.toUpperCase()===prenom;});
+  if(rk){var re=A.employees.find(function(e){return e.id===rk;});if(re)return re;}
+  // Génère les candidats d'initiales à tester depuis le prénom complet
+  // ex. "JEAN" → ["J","JE"] ; "JEAN-PIERRE" → ["J","JE","JP"]
+  function inits(p){
+    var r=[];
+    if(p.length>=1)r.push(p[0]);
+    if(p.length>=2)r.push(p.substring(0,2));
+    var w=p.split(/[\s\-]+/).filter(function(x){return x.length>0;});
+    if(w.length>=2){var ci=w.map(function(x){return x[0];}).join("").substring(0,2);if(r.indexOf(ci)<0)r.push(ci);}
+    return r;
+  }
+  var cands=inits(prenom);
+  function searchSrc(list){
+    // Essai exact pour chaque candidat d'initiales
+    for(var i=0;i<cands.length;i++){
+      var f=list.find(function(e){return e.name===nomBase+cands[i];});
+      if(f)return f;
+    }
+    // Fallback : les initiales STOCKÉES doivent être un préfixe du prénom saisi
+    return list.find(function(e){
+      if(e.name.indexOf(nomBase)!==0)return false;
+      var stored=e.name.slice(nomBase.length).toUpperCase();
+      return prenom.indexOf(stored)===0;
+    })||null;
+  }
+  return searchSrc(src||A.employees)||searchSrc(DEF_EMP)||null;
+}
