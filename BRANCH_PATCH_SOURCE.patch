+// Helper : retourne toutes les salles (CMC) ou zones (CDP) qui proposent un jeu donn\u00e9
+// jid peut \u00eatre un id (bj, ra, re, pb, thu, craps, tcp) ou un label ("Black-Jack", "Roulette"...)
+function findSallesPourJeu(jid,etab){
+  var etabs=etab==="cmc"?[{k:"cmc",data:PLANS_CMC,key:"salles"}]:etab==="cdp"?[{k:"cdp",data:PLANS_CDP,key:"zones"}]:[{k:"cmc",data:PLANS_CMC,key:"salles"},{k:"cdp",data:PLANS_CDP,key:"zones"}];
+  var labelMap={bj:"Black-Jack",ra:"Roulette anglaise",re:"Roulette europ\u00e9enne",pb:"Punto Banco",phr:"Punto Banco",thu:"Texas Hold'em",craps:"Craps",tcp:"Three Card Poker",cg:"Poker"};
+  var needle=(labelMap[jid]||jid||"").toLowerCase();
+  var results=[];
+  etabs.forEach(function(e){
+    (e.data[e.key]||[]).forEach(function(s){
+      if((s.jeux||[]).some(function(j){return j.toLowerCase().indexOf(needle)>=0;})){
+        results.push({etab:e.k,nom:s.nom,id:s.id});
+      }
+    });
+  });
+  return results;
+}
