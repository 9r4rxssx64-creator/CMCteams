+  };
+  var userLog=lg("cmc_userlog",[]);
+  var lastLoginByUid={};
+  userLog.forEach(function(l){
+    if(l.uid&&(!lastLoginByUid[l.uid]||l.ts>lastLoginByUid[l.uid])){
+      lastLoginByUid[l.uid]=l.ts;
+    }
+  });
+  A.employees.forEach(function(emp){
+    if(!isEmpActive(emp,A.year,A.month))return;
