+      (byTeam[e.team]=byTeam[e.team]||[]).push(e.name+(e.suggestions&&e.suggestions.length?" [similaires: "+e.suggestions.join(", ")+"]":""));
+    });
+    Object.keys(byTeam).sort().forEach(function(t){
+      lines.push("  Equipe "+t+":");
+      byTeam[t].forEach(function(n){lines.push("    - "+n);});
+    });
+    lines.push("");
