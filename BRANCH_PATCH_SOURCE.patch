+// Helper : recherche dans le cadre l\u00e9gal (LOI_1103 + OS_8929 + AM_88_384)
+function searchLoi(query){
+  if(!query)return[];
+  var q=query.toLowerCase(),results=[];
+  // LOI 1.103
+  LOI_1103.sections.forEach(function(sec){
+    (sec.articles||[]).forEach(function(a){
+      if(a.titre.toLowerCase().indexOf(q)>=0||a.contenu.toLowerCase().indexOf(q)>=0)
+        results.push({source:"Loi 1.103",article:a.num,titre:a.titre,extrait:a.contenu.slice(0,200)});
+    });
+  });
+  // AM 88-384
+  AM_88_384.chapitres.forEach(function(ch){
+    (ch.articles||[]).forEach(function(a){
+      if(a.contenu.toLowerCase().indexOf(q)>=0)
+        results.push({source:"AM 88-384",article:a.num,titre:"Ch."+ch.num+" "+ch.titre,extrait:a.contenu.slice(0,200)});
+    });
+  });
+  // OS 8929
+  if(OS_8929.jeuxAutorises.some(function(j){return j.toLowerCase().indexOf(q)>=0;}))
+    results.push({source:"OS 8.929",article:"-",titre:"Jeux autoris\u00e9s",extrait:OS_8929.jeuxAutorises.filter(function(j){return j.toLowerCase().indexOf(q)>=0;}).join(", ")});
+  return results;
+}
